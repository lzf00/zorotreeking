# === 微信推送配置（二选一）===

# 方式一：pushplus（推荐，免费简单）
# 注册地址：https://www.pushplus.plus/
PUSHPLUS_TOKEN=your_pushplus_token_here

# 方式二：Server酱
# 注册地址：https://sct.ftqq.com/
# SERVERCHAN_KEY=your_serverchan_key_here

# === 股票配置 ===
# A 股观察池（Wind 格式 600519.SH 或旧格式 sh600519 都支持）
STOCK_CODES=600519.SH,601318.SH,000858.SZ,300750.SZ,688981.SH

# 港股观察池（Wind 格式 01810.HK；留空则禁用港股看板）
HK_STOCK_CODES=01810.HK,00700.HK,03690.HK,01211.HK,09988.HK

# 推送时间（24小时制，多个时间用逗号分隔）
PUSH_TIMES=10:30,15:30

# === 数据源 ===
# Wind 万得，依赖 ~/.agents/skills/wind-mcp-skill
# WIND_API_KEY 配置：node ~/.agents/skills/wind-mcp-skill/scripts/cli.mjs setup-key <KEY> --scope global

# === zorotreeking 归档 ===
# stock_pusher 在 services/stock_pusher/ 下时自动推断 repo 根；
# 仅在非子目录部署时设置：
# ZOROTREEKING_REPO_PATH=/path/to/zorotreeking
