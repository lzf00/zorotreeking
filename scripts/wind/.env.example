# scripts/wind 环境变量模板
# 在 /opt/wind-recap/.env (服务器) 或本目录 .env (本地) 复制此文件并填值。
# systemd 单元用 EnvironmentFile= 读取，cron 用 dotenv 加载。

# === 股票配置（必填）===
# A 股观察池（逗号分隔；Wind 格式 600519.SH 或旧格式 sh600519 都支持）
STOCK_CODES=600519.SH,601318.SH,000858.SZ,300750.SZ,688981.SH

# 港股观察池（Wind 格式 01810.HK；留空则禁用港股；开盘版任何时候都不拉港股）
HK_STOCK_CODES=01810.HK,00700.HK,03690.HK,01211.HK,09988.HK

# === 微信推送（二选一）===
SERVERCHAN_KEY=SCTxxx...
# PUSHPLUS_TOKEN=ppxxx...

# === GitHub 归档（仅 run_close.py 用）===
# 触发 publisher 走 GitHub Git Data API（避开 github.com:443 在国内被墙）
# Token 需 repo scope。生成：https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=ghp_xxx...
GITHUB_REPO=lzf00/zorotreeking
GITHUB_BRANCH=main

# 备用：仅 GITHUB_TOKEN 未设时使用，指向本地 git clone
# ZOROTREEKING_REPO_PATH=/path/to/zorotreeking

# === Wind 数据源 ===
# wind-mcp-skill 安装位置；服务器一般在 /opt/wind-mcp-skill
# 本机默认 ~/.agents/skills/wind-mcp-skill 无需配置
# WIND_SKILL_DIR=/opt/wind-mcp-skill

# WIND_API_KEY 通过 `node $WIND_SKILL_DIR/scripts/cli.mjs setup-key <KEY> --scope global`
# 写入 ~/.wind-aifinmarket/config，不在此 env 配

# === 并发与调优 ===
# fetch_all_data 并发 worker 数；4-6 比较稳，太高会触发 Wind "并发请求次数超限"
# WIND_MAX_WORKERS=5

# === Node 可执行文件覆盖 ===
# 仅在 PATH 找不到 node 且非标准路径时显式指定（如 nvm 装的特殊版本）
# NODE_BIN=/root/.nvm/versions/node/v22.0.0/bin/node

# === SSL 调试 ===
# 推送 SSL 校验默认开；仅 macOS LibreSSL 报错时设 1 跳过
# SKIP_SSL_VERIFY=0
