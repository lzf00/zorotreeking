{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMultipleMajorReleases",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "prConcurrentLimit": 3,
  "prHourlyLimit": 1,
  "schedule": ["before 6am on monday"],
  "timezone": "Asia/Shanghai",
  "packageRules": [
    {
      "description": "Minor/patch 自动合并（passes CI 时）",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Major 单独 PR 让人审",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "automerge": false
    },
    {
      "description": "Astro / 主框架 慎合并",
      "matchPackageNames": ["astro", "@astrojs/mdx", "@astrojs/react", "@astrojs/tailwind", "@astrojs/rss"],
      "automerge": false,
      "labels": ["dependencies", "astro"]
    },
    {
      "description": "React 18 锁住，不自动升 19",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "allowedVersions": "^18"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  }
}
