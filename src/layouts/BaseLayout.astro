---
import "@/styles/global.css";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import AIChatWidget from "@/components/AIChatWidget";
import SearchModal from "@/components/SearchModal";
import ArticleImageLightbox from "@/components/ArticleImageLightbox.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/ui";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: Date;     // 文章发布时间（仅 article 用）
  modifiedTime?: Date;
  tags?: string[];          // article:tag
}

const { title, description, ogImage, ogType = "website", publishedTime, modifiedTime, tags } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const fullTitle = title ? `${title} · ${t("site.title")}` : `${t("site.title")} — ${t("site.tagline")}`;
const desc = description ?? t("site.tagline");
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// ── JSON-LD 结构化数据（schema.org） ──
// 让 Google / Bing / 微信分享等理解每个页面的语义。
// Article 页输出 Article，首页输出 WebSite + Person，about 输出 Person，其它 WebPage。
const siteName = "ZoroTreeking";
const author = {
  "@type": "Person",
  name: "Zifei Liu",
  alternateName: "Zoro",
  url: new URL("/about", Astro.site).toString(),
  sameAs: ["https://github.com/lzf00"],
};

let jsonLd: object | null = null;
if (ogType === "article") {
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title ?? siteName,
    description: desc,
    image: ogImage ? new URL(ogImage, Astro.site).toString() : undefined,
    datePublished: publishedTime?.toISOString(),
    dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
    author,
    publisher: { "@type": "Organization", name: siteName, url: Astro.site?.toString() },
    mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
    keywords: tags?.join(", "),
    inLanguage: lang === "zh" ? "zh-CN" : "en",
  };
} else if (Astro.url.pathname === "/" || Astro.url.pathname === "/en/" || Astro.url.pathname === "/en") {
  jsonLd = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: Astro.site?.toString(),
    description: t("site.tagline"),
    inLanguage: lang === "zh" ? "zh-CN" : "en",
    author,
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${Astro.site?.toString().replace(/\/$/, "")}/?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    },
  };
} else if (Astro.url.pathname === "/about" || Astro.url.pathname === "/about/" ||
           Astro.url.pathname === "/en/about" || Astro.url.pathname === "/en/about/") {
  jsonLd = {
    "@context": "https://schema.org",
    ...author,
    description: desc,
    image: ogImage ? new URL(ogImage, Astro.site).toString() : undefined,
  };
}
---

<!doctype html>
<html lang={lang === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Security headers (meta 层；完整版在 nginx 层，见 docs/security-headers.md) */}
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="format-detection" content="telephone=no,date=no,address=no,email=no" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh" href={new URL(Astro.url.pathname.replace(/^\/en(\/|$)/, "/"), Astro.site).toString()} />
    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.startsWith("/en") ? Astro.url.pathname : `/en${Astro.url.pathname}`, Astro.site).toString()} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    {ogType === "article" && tags && tags.map((t) => <meta property="article:tag" content={t} />)}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd, (_, v) => v === undefined ? undefined : v)} />}
    {/* 搜索引擎站长验证（GitHub repo Variables 配后自动注入） */}
    {import.meta.env.PUBLIC_GOOGLE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_VERIFICATION} />
    )}
    {import.meta.env.PUBLIC_BAIDU_VERIFICATION && (
      <meta name="baidu-site-verification" content={import.meta.env.PUBLIC_BAIDU_VERIFICATION} />
    )}
    {import.meta.env.PUBLIC_BING_VERIFICATION && (
      <meta name="msvalidate.01" content={import.meta.env.PUBLIC_BING_VERIFICATION} />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1d1d1f" />
    <link rel="alternate" type="application/rss+xml" title="ZoroTreeking · RSS" href="/rss.xml" />
    <link rel="alternate" type="application/atom+xml" title="ZoroTreeking · Atom" href="/atom.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- editorial 字体组合：Instrument Serif（display）+ Inter（body）+ JetBrains Mono（code） -->
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- A11y skip-to-content：键盘用户按 Tab 第一个出现这个；视觉默认隐藏，focus 时浮在左上角 -->
    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[999]
              focus:px-4 focus:py-2 focus:rounded-lg focus:bg-black focus:text-white
              focus:text-sm focus:font-medium focus:shadow-lg">
      跳到正文 / Skip to content
    </a>
    <Navbar />
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <!-- 悬浮 AI 助手（react island，仅在浏览器空闲后加载） -->
    <AIChatWidget client:idle />
    <!-- 全站搜索 modal（pagefind，仅在空闲时加载） -->
    <SearchModal client:idle />
    <!-- 文章正文图片 lightbox（点击放大） -->
    <ArticleImageLightbox />
    <!-- 代码块复制按钮（mdx 文章里的 <pre> 自动加 copy） -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll("article pre").forEach((pre) => {
          if (pre.querySelector(".code-copy-btn")) return;
          pre.style.position = "relative";
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "code-copy-btn";
          btn.setAttribute("aria-label", "复制代码");
          btn.textContent = "Copy";
          btn.style.cssText = "position:absolute;top:8px;right:8px;font-size:11px;padding:3px 8px;border-radius:6px;background:rgba(255,255,255,0.08);color:#9ca3af;border:1px solid rgba(255,255,255,0.12);cursor:pointer;font-family:'JetBrains Mono',monospace;opacity:0;transition:opacity 0.15s,background 0.15s";
          pre.addEventListener("mouseenter", () => { btn.style.opacity = "1"; });
          pre.addEventListener("mouseleave", () => { btn.style.opacity = "0"; });
          btn.addEventListener("click", async () => {
            const code = pre.querySelector("code")?.textContent || pre.textContent || "";
            try {
              await navigator.clipboard.writeText(code);
              btn.textContent = "✓ Copied";
              btn.style.color = "#16a34a";
              setTimeout(() => { btn.textContent = "Copy"; btn.style.color = "#9ca3af"; }, 1600);
            } catch {
              btn.textContent = "✗ failed";
              setTimeout(() => { btn.textContent = "Copy"; }, 1600);
            }
          });
          pre.appendChild(btn);
        });
      });
    </script>
    <!-- 轻量页面访问统计：每次浏览发一个 POST，失败静默 -->
    <script is:inline>
      (() => {
        try {
          const path = location.pathname + location.search;
          const ref = document.referrer && !document.referrer.includes(location.host) ? document.referrer : null;
          fetch("/api/track", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ path, referrer: ref }),
            keepalive: true,
          }).catch(() => {});
        } catch (_) {}
      })();
    </script>
  </body>
</html>
