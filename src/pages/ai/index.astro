---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagChip from "@/components/TagChip.astro";
import PostCard from "@/components/PostCard.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";
import { extractDigestHighlights } from "@/lib/digest-highlights";

const lang = "zh" as const;
const t = useTranslations(lang);

const all = (await getCollection("ai", p => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const isDigest = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");

const posts = all.filter(p => !isDigest(p));
const digests = all.filter(isDigest);
const latestDigest = digests[0];
---

<BaseLayout title={t("section.ai.title")} description={t("section.ai.desc")}>
  <section class="max-w-3xl mx-auto px-5 pt-12 pb-6">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight" style="color:#1d4ed8">{t("section.ai.title")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{t("section.ai.desc")}</p>
  </section>

  <!-- 原创笔记列表（PostCard 带 section 色块 thumbnail） -->
  <section class="max-w-3xl mx-auto px-5">
    <ul class="divide-y divide-[var(--border)]">
      {posts.map(p => (
        <li>
          <PostCard
            href={pathWithLang(`/ai/${p.data.translationKey}`, lang)}
            title={p.data.title}
            description={p.data.description}
            date={p.data.date}
            section="ai"
            cover={p.data.cover}
            tags={p.data.tags} />
        </li>
      ))}
      {posts.length === 0 && <li class="py-12 text-center text-[var(--text-tertiary)]">原创笔记还在路上。</li>}
    </ul>
  </section>

  <!-- 自动日报入口卡（不进列表，独立归档） -->
  {digests.length > 0 && (
    <section class="max-w-3xl mx-auto px-5 mt-16">
      <a href={pathWithLang("/ai/digest", lang)}
         class="group block border border-[var(--border)] rounded-xl p-5 hover:border-section-ai transition-colors">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.15em] text-[var(--text-tertiary)] font-mono mb-1">
              Auto Digest
            </div>
            <h3 class="text-base font-semibold group-hover:text-section-ai transition-colors">
              AI 每日精选 · 自动日报 →
            </h3>
            <p class="mt-1 text-sm text-[var(--text-secondary)] line-clamp-1">
              cron 每日 08:00 抓取 HF Daily Papers + arxiv + 量子位 + Anthropic / OpenAI 等
            </p>
          </div>
          <div class="text-right shrink-0">
            <div class="text-2xl font-semibold tabular-nums">{digests.length}</div>
            <div class="text-[11px] uppercase tracking-wider text-[var(--text-tertiary)]">期</div>
          </div>
        </div>
        {latestDigest && (
          <div class="mt-3 pt-3 border-t border-[var(--border)] text-xs text-[var(--text-tertiary)]">
            最新一期：{latestDigest.data.date.toISOString().slice(0, 10)} · {latestDigest.data.description}
          </div>
        )}
      </a>
    </section>
  )}
</BaseLayout>
