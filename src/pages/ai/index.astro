---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagChip from "@/components/TagChip.astro";
import PostCard from "@/components/PostCard.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";
import { extractDigestHighlights } from "@/lib/digest-highlights";

const lang = "zh" as const;
const t = useTranslations(lang);

const all = (await getCollection("ai", p => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const isDigest = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");

const posts = all.filter(p => !isDigest(p));
const digests = all.filter(isDigest);
const recentDigests = digests.slice(0, 3);
const latestDigest = digests[0];
---

<BaseLayout title={t("section.ai.title")} description={t("section.ai.desc")}>
  <section class="max-w-3xl mx-auto px-5 pt-12 pb-6">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight" style="color:#1d4ed8">{t("section.ai.title")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{t("section.ai.desc")}</p>
  </section>

  <!-- ── 区一：原创笔记（个人观点，慢速产出） ── -->
  <section class="max-w-3xl mx-auto px-5">
    <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-[var(--border)]">
      <h2 class="text-lg font-semibold tracking-tight">🧠 原创笔记</h2>
      <span class="text-xs text-[var(--text-tertiary)] font-mono">
        {posts.length} 篇 · 深度分析
      </span>
    </div>
    <ul class="divide-y divide-[var(--border)]">
      {posts.map(p => (
        <li>
          <PostCard
            href={pathWithLang(`/ai/${p.data.translationKey}`, lang)}
            title={p.data.title}
            description={p.data.description}
            date={p.data.date}
            section="ai"
            cover={p.data.cover}
            tags={p.data.tags} />
        </li>
      ))}
      {posts.length === 0 && (
        <li class="py-8 text-center text-sm text-[var(--text-tertiary)]">
          原创笔记还在路上，每月 1-2 篇深度分析。
        </li>
      )}
    </ul>
    {posts.length > 0 && posts.length < 8 && (
      <p class="mt-4 text-xs text-[var(--text-tertiary)] italic">
        原创产出较慢（每月 1-2 篇深度分析），下方 <a href={pathWithLang("/ai/digest", lang)} class="underline hover:text-section-ai">AI 每日精选</a> 是自动化产出的高信噪比日报，每天都有新内容。
      </p>
    )}
  </section>

  <!-- ── 区二：AI 每日精选（自动化产出，86 期归档） ── -->
  {digests.length > 0 && (
    <section class="max-w-3xl mx-auto px-5 mt-16">
      <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-[var(--border)]">
        <h2 class="text-lg font-semibold tracking-tight">📰 AI 每日精选</h2>
        <span class="text-xs text-[var(--text-tertiary)] font-mono">
          {digests.length} 期 · cron 每日 08:00
        </span>
      </div>
      <p class="mb-4 text-sm text-[var(--text-secondary)] leading-relaxed">
        自动化抓取 HF Daily Papers + arXiv cs.LG + OpenAI / Anthropic / DeepMind / 量子位 等，豆包翻译成中文摘要，附 3 句 TL;DR + emoji 标签。全部 <strong>中英双语</strong>。
      </p>

      <!-- 最近 3 期快速预览 -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
        {recentDigests.map(d => (
          <a href={pathWithLang(`/ai/${d.data.translationKey}`, lang)}
             class="group block rounded-lg overflow-hidden border border-[var(--border)] hover:border-section-ai transition-colors">
            {d.data.cover && (
              <div class="aspect-[16/9] overflow-hidden bg-zinc-100 dark:bg-zinc-800">
                <img src={d.data.cover} alt={d.data.title}
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                     loading="lazy" />
              </div>
            )}
            <div class="p-3">
              <time class="text-[10px] uppercase tracking-[0.15em] text-[var(--text-tertiary)] font-mono">
                {d.data.date.toISOString().slice(0, 10)}
              </time>
              <h3 class="mt-0.5 text-sm font-semibold leading-snug group-hover:text-section-ai transition-colors line-clamp-2">
                {d.data.title}
              </h3>
            </div>
          </a>
        ))}
      </div>

      <a href={pathWithLang("/ai/digest", lang)}
         class="group flex items-center justify-between border border-[var(--border)] rounded-lg p-4 hover:border-section-ai transition-colors">
        <div>
          <div class="text-base font-semibold group-hover:text-section-ai transition-colors">
            📚 查看全部 {digests.length} 期归档 →
          </div>
          <p class="mt-1 text-xs text-[var(--text-tertiary)]">
            按月分组 · 每期含 TL;DR + 封面图 · 支持搜索
          </p>
        </div>
        <span class="text-2xl text-[var(--text-tertiary)] group-hover:translate-x-1 group-hover:text-section-ai transition-all">→</span>
      </a>
    </section>
  )}
</BaseLayout>
