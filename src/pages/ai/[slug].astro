---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FeedbackButtons from "@/components/FeedbackButtons";
import TOC from "@/components/TOC.astro";
import TagChip from "@/components/TagChip.astro";
import Giscus from "@/components/Giscus.astro";
import { estimateReadingTime } from "@/lib/reading-time";
import { useTranslations, pathWithLang } from "@/i18n/ui";

export async function getStaticPaths() {
  const all = await getCollection("ai", (p) => p.data.lang === "zh" && !p.data.draft);
  return all.map((entry) => ({ params: { slug: entry.data.translationKey }, props: { entry } }));
}

interface Props { entry: CollectionEntry<"ai"> }
const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const lang = "zh" as const;
const t = useTranslations(lang);
const readMins = estimateReadingTime(entry.body);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <TOC headings={headings} label="目录" />
  <article class="max-w-prose mx-auto px-5 pt-12 pb-16">
    <header class="mb-8">
      <a href={pathWithLang("/ai", lang)} class="text-sm text-section-ai hover:underline">← {t("section.ai.title")}</a>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight leading-tight">{entry.data.title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--text-tertiary)]">
        <time>{entry.data.date.toISOString().slice(0, 10)}</time>
        <span>·</span>
        <span>{readMins} {t("post.readTime")}</span>
        {entry.data.tags.map((tag) => <TagChip tag={tag} lang={lang} />)}
      </div>
    </header>
    <div class="prose prose-neutral dark:prose-invert max-w-none prose-headings:tracking-tight prose-a:text-section-ai prose-pre:bg-[#0d1117] prose-pre:rounded-xl prose-headings:scroll-mt-20">
      <Content />
    </div>
    <FeedbackButtons slug={`ai/${entry.data.translationKey}`} client:visible />
    <Giscus />
  </article>
</BaseLayout>
