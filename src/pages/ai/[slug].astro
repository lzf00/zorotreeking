---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";

export async function getStaticPaths() {
  const all = await getCollection("ai", p => p.data.lang === "zh" && !p.data.draft);
  return all.map((entry) => ({
    params: { slug: entry.data.translationKey },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<"ai"> }
const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await entry.render();
const lang = "zh" as const;
const t = useTranslations(lang);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-prose mx-auto px-5 pt-12 pb-16">
    <header class="mb-8">
      <a href={pathWithLang("/ai", lang)} class="text-sm text-section-ai hover:underline">← {t("section.ai.title")}</a>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight leading-tight">{entry.data.title}</h1>
      <div class="mt-3 flex items-center gap-3 text-xs text-[var(--text-tertiary)]">
        <time>{entry.data.date.toISOString().slice(0, 10)}</time>
        {entry.data.tags.map(tag => <span class="px-1.5 py-0.5 rounded bg-[var(--bg-soft)]">#{tag}</span>)}
      </div>
    </header>
    <div class="prose prose-neutral dark:prose-invert max-w-none prose-headings:tracking-tight prose-a:text-section-ai">
      <Content />
    </div>
  </article>
</BaseLayout>
