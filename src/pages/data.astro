---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="我的数据" description="查看与删除本站收集的关于你的访问记录">
  <article class="max-w-prose mx-auto px-5 pt-16 pb-24">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight mb-6">我的数据</h1>
    <p class="text-[var(--text-secondary)] mb-8">
      本站对未注册的访客只收集匿名记录（IP+UA 哈希指纹、访问路径、时间戳）。
      在这里你可以<strong>查看本站存了哪些关于你的记录</strong>，并随时<strong>一键删除</strong>。
    </p>

    <div class="prose prose-neutral dark:prose-invert max-w-none">

      <section class="not-prose mb-10">
        <button id="loadBtn" class="inline-flex items-center gap-2 rounded-full bg-black dark:bg-white text-white dark:text-black px-5 py-2.5 text-sm font-medium hover:opacity-90 transition-opacity">
          查看我的记录
        </button>
        <span id="loadHint" class="ml-3 text-sm text-[var(--text-tertiary)]"></span>
      </section>

      <section id="dataBox" class="hidden not-prose mb-10">
        <div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-soft)] p-5">
          <div class="text-xs uppercase tracking-[0.16em] text-[var(--text-tertiary)] font-mono mb-2">你的访客指纹</div>
          <code id="fp" class="font-mono text-sm select-all"></code>
          <span id="ipPartial" class="ml-2 text-xs text-[var(--text-tertiary)]"></span>

          <hr class="my-5 border-[var(--border)]" />

          <div class="grid grid-cols-3 gap-3 mb-5" id="counts">
            <!-- 注入：feedback / pageviews / filtered_chats 三个计数卡 -->
          </div>

          <div class="text-xs uppercase tracking-[0.16em] text-[var(--text-tertiary)] font-mono mb-2">最近 10 条访问路径</div>
          <ul id="recent" class="text-sm font-mono space-y-1 text-[var(--text-secondary)]"></ul>
        </div>

        <div class="mt-6 flex items-center gap-3 flex-wrap">
          <button id="deleteBtn" class="inline-flex items-center gap-2 rounded-full bg-red-600 hover:bg-red-700 text-white px-5 py-2.5 text-sm font-medium transition-colors">
            一键删除我的全部记录
          </button>
          <span id="deleteHint" class="text-sm text-[var(--text-tertiary)]"></span>
        </div>
      </section>

      <h2>说明</h2>
      <ul>
        <li><strong>指纹是什么</strong>：你的 IP 与 User-Agent 拼接后做 SHA-256 哈希，截取前 32 字符。同 IP+UA 拿到的指纹一样，<strong>无法反推回 IP</strong>。</li>
        <li><strong>删除做了什么</strong>：本接口会把 <code>feedback</code>、<code>pageviews</code>、<code>chat_filtered_log</code> 三张表里指纹等于你的记录全部物理删除。处置动作会在 <code>moderation_log</code> 留痕（仅记 IP + 删除数，不留你的指纹）。</li>
        <li><strong>删完之后还会再被记录吗</strong>：会。你下次访问会再次生成 pageview 记录。如果想<strong>完全停止</strong>记录，请关闭本页或不再访问。</li>
        <li><strong>nginx 访问日志</strong>：服务器层的访问日志（仅运维与执法部门可访问，留存 ≤ 200 天）<strong>不在本接口覆盖范围</strong>。若有需要从访问日志中删除你的记录，请发邮件 <a href="mailto:1437066318@qq.com">1437066318@qq.com</a> 并附时间窗口。</li>
        <li><strong>关于 AI 对话</strong>：本站 AI 助手的对话历史保存在<strong>服务器内存</strong>，重启或长时间不活动会自动消失；当前会话也可在 AI 窗口内点"清除对话"立即清掉。</li>
      </ul>

      <p class="text-sm text-[var(--text-tertiary)]">如需进一步协助：<a href="mailto:1437066318@qq.com">1437066318@qq.com</a> · <a href="/privacy">完整隐私政策</a> · <a href="/contact">投诉举报</a></p>
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (() => {
    const $ = (id) => document.getElementById(id);
    const fmtTime = (ts) => new Date(ts * 1000).toLocaleString("zh-CN", { hour12: false });

    async function loadMe() {
      $("loadBtn").disabled = true;
      $("loadHint").textContent = "加载中…";
      try {
        const r = await fetch("/api/data/me");
        if (!r.ok) throw new Error(r.status);
        const d = await r.json();
        $("fp").textContent = d.fingerprint;
        $("ipPartial").textContent = "IP 大致：" + (d.ip_partial || "");
        $("counts").innerHTML = [
          ["点赞 / 不喜欢记录", d.counts.feedback],
          ["页面访问记录",       d.counts.pageviews],
          ["敏感词拦截记录",      d.counts.filtered_chats],
        ].map(([l, n]) => `
          <div class="rounded-xl bg-white dark:bg-neutral-900 border border-[var(--border)] p-3 text-center">
            <div class="text-[11px] uppercase tracking-[0.12em] text-[var(--text-tertiary)]">${l}</div>
            <div class="mt-1 text-2xl font-semibold tabular-nums">${n}</div>
          </div>
        `).join("");
        const pv = d.recent_pageviews || [];
        $("recent").innerHTML = pv.length
          ? pv.map(p => `<li><span class="text-[var(--text-tertiary)]">${fmtTime(p.ts)}</span> &nbsp; ${p.path}</li>`).join("")
          : '<li class="text-[var(--text-tertiary)]">无</li>';
        $("dataBox").classList.remove("hidden");
        $("loadHint").textContent = "已加载";
      } catch (e) {
        $("loadHint").textContent = "加载失败：" + e.message;
        $("loadBtn").disabled = false;
      }
    }

    async function deleteMe() {
      if (!confirm("确定要删除本站存的关于你的全部访问记录吗？此操作不可撤销。")) return;
      $("deleteBtn").disabled = true;
      $("deleteHint").textContent = "处理中…";
      try {
        const r = await fetch("/api/data/delete", { method: "POST" });
        const d = await r.json();
        if (d.ok) {
          $("deleteHint").innerHTML = `<span style="color:#16a34a">已删除：feedback ${d.deleted.feedback} 条 · pageviews ${d.deleted.pageviews} 条 · 拦截 ${d.deleted.filtered_chats} 条</span>`;
          setTimeout(loadMe, 400);
        } else {
          $("deleteHint").innerHTML = '<span style="color:#dc2626">删除失败</span>';
        }
      } catch (e) {
        $("deleteHint").innerHTML = `<span style="color:#dc2626">出错：${e.message}</span>`;
      } finally {
        $("deleteBtn").disabled = false;
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      $("loadBtn").addEventListener("click", loadMe);
      $("deleteBtn").addEventListener("click", deleteMe);
    });
  })();
</script>
