---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionCard from "@/components/SectionCard.astro";
import { useTranslations, pathWithLang, defaultLang } from "@/i18n/ui";
import { aboutData } from "@/data/about";

const lang = defaultLang;
const t = useTranslations(lang);

// digest 类自动日报不进首页"最近更新"——首页只展示原创笔记。
// 判断标准：tags 含 "digest" 或 translationKey 以 "digest-" 开头。
const isDigest = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");

const [aiPosts, investPosts, photoAlbums, hikes] = await Promise.all([
  getCollection("ai", (p) => p.data.lang === lang && !p.data.draft),
  getCollection("invest", (p) => p.data.lang === lang && !p.data.draft),
  getCollection("photo", (p) => p.data.lang === lang && !p.data.draft),
  getCollection("hike", (p) => p.data.lang === lang && !p.data.draft),
]);

// 栏目卡片展示的"原创数"也用过滤后的，避免"AI 23 篇"骗访客
const aiOriginal = aiPosts.filter(p => !isDigest(p));
const investOriginal = investPosts.filter(p => !isDigest(p));

// 副标注：自动化产出（digest/market-recap）数量
const aiDigestCount = aiPosts.filter(p => isDigest(p)).length;
const investDigestCount = investPosts.filter(p => isDigest(p)).length;
const investRecapCount = investPosts.filter(p =>
  (p.data.tags ?? []).includes("market-recap") || p.data.translationKey.startsWith("market-recap-")
).length;

const latest = [
  ...aiOriginal.map(p => ({ ...p, section: "ai" as const })),
  ...investOriginal.map(p => ({ ...p, section: "invest" as const })),
  ...photoAlbums.map(p => ({ ...p, section: "photo" as const })),
  ...hikes.map(p => ({ ...p, section: "hike" as const })),
]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);

// ── 首页"精选阅读" 3 张大卡（首屏内容钩子）──
// 选 1: 最近的原创长文（按 body 长度 + 原创优先）
// 选 2: 本周最新 digest（让访客感知"今天就有新内容"）
// 选 3: 一篇摄影 / 徒步（让访客看到非文字内容）
function pickHero() {
  const originals = [
    ...aiOriginal.map(p => ({ ...p, section: "ai" as const })),
    ...investOriginal.map(p => ({ ...p, section: "invest" as const })),
  ].sort((a, b) => (b.body?.length ?? 0) - (a.body?.length ?? 0));

  const latestDigest = [
    ...aiPosts.filter(isDigest).map(p => ({ ...p, section: "ai" as const })),
    ...investPosts.filter(isDigest).map(p => ({ ...p, section: "invest" as const })),
  ].sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

  const latestVisual = [
    ...photoAlbums.map(p => ({ ...p, section: "photo" as const })),
    ...hikes.map(p => ({ ...p, section: "hike" as const })),
  ].sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

  return [originals[0], latestDigest, latestVisual].filter(Boolean).slice(0, 3);
}
const featured = pickHero();

const sectionGradient: Record<string, string> = {
  ai: "from-blue-50 to-blue-100/40 dark:from-blue-950/40 dark:to-blue-900/20",
  invest: "from-red-50 to-red-100/40 dark:from-red-950/40 dark:to-red-900/20",
  photo: "from-purple-50 to-purple-100/40 dark:from-purple-950/40 dark:to-purple-900/20",
  hike: "from-green-50 to-green-100/40 dark:from-green-950/40 dark:to-green-900/20",
};

const sectionLabel = {
  ai: t("nav.ai"),
  invest: t("nav.invest"),
  photo: t("nav.photo"),
  hike: t("nav.hike"),
};
const sectionAccent: Record<string, string> = {
  ai: "#1d4ed8",
  invest: "#991b1b",
  photo: "#6b21a8",
  hike: "#166534",
};
---

<BaseLayout>
  <!-- ── Hero（Apple 风：大字、留白、清晰副标题） ── -->
  <section class="max-w-5xl mx-auto px-5 pt-20 sm:pt-32 pb-16 sm:pb-24 text-center">
    <h1 class="text-5xl sm:text-7xl font-semibold tracking-tight leading-[1.05] animate-rise">
      在代码与山林之间，<br />
      留一份缓慢的笔记。
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-[var(--text-secondary)] max-w-2xl mx-auto leading-relaxed animate-rise delay-100">
      关于 AI、投资、摄影、徒步的个人记录。
    </p>
    <div class="mt-10 flex items-center justify-center gap-4 animate-rise delay-200">
      <a href={pathWithLang("/ai", lang)} class="inline-flex items-center gap-1.5 rounded-full bg-black dark:bg-white text-white dark:text-black px-5 py-2.5 text-sm font-medium hover:opacity-90 transition-opacity">
        开始阅读
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
      <a href={pathWithLang("/about", lang)} class="inline-flex items-center text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors">
        关于我 →
      </a>
    </div>
  </section>

  <!-- ── 个人锚点（新访客第一眼知道"这是谁的博客"） ── -->
  <section class="max-w-4xl mx-auto px-5 pb-12 sm:pb-16 animate-rise delay-300">
    <div class="rounded-2xl border border-[var(--border)] p-5 sm:p-7 bg-[var(--surface-1)]">
      <div class="flex items-start gap-4 sm:gap-5">
        <!-- initials 圆圈头像 -->
        <div class="shrink-0 w-16 h-16 sm:w-20 sm:h-20 rounded-2xl
                    bg-gradient-to-br from-blue-100 via-purple-100 to-green-100
                    dark:from-blue-950/40 dark:via-purple-950/40 dark:to-green-950/40
                    flex items-center justify-center"
             aria-hidden="true">
          <span class="font-serif text-2xl sm:text-3xl text-zinc-700 dark:text-zinc-200">ZL</span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline gap-2 flex-wrap">
            <h2 class="text-base sm:text-lg font-semibold tracking-tight">{aboutData.name}</h2>
            <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-[0.15em]">a.k.a. {aboutData.alias}</span>
          </div>
          <p class="mt-1.5 text-sm sm:text-[15px] leading-relaxed text-[var(--text-secondary)]">
            软件工程师，日常在数据与 AI 的交叉地带。这里同时有 <a href={pathWithLang("/ai", lang)} class="text-section-ai hover:underline font-medium">AI 论文中文笔记</a> ·
            <a href={pathWithLang("/invest", lang)} class="text-section-invest hover:underline font-medium ml-1">A 股 / 港股实时看板</a> ·
            <a href={pathWithLang("/photo", lang)} class="text-section-photo hover:underline font-medium ml-1">相机瞬间</a> ·
            <a href={pathWithLang("/hike", lang)} class="text-section-hike hover:underline font-medium ml-1">徒步轨迹</a>。
            无算法、无推送、无广告。
          </p>
          <div class="mt-3 flex items-center gap-3 flex-wrap text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">
            <a href={pathWithLang("/now", lang)} class="hover:text-[var(--text)] transition-colors">
              📍 我最近在做什么
            </a>
            <span class="opacity-40">·</span>
            <a href={pathWithLang("/about", lang)} class="hover:text-[var(--text)] transition-colors">
              👋 关于我
            </a>
            <span class="opacity-40">·</span>
            <a href="/rss.xml" class="hover:text-[var(--text)] transition-colors">
              🎯 RSS 订阅
            </a>
          </div>
        </div>
      </div>

      <!-- 全站搜索快捷入口（客户端触发 SearchModal） -->
      <button type="button" id="home-search-trigger"
              class="mt-4 w-full flex items-center gap-3 rounded-xl border border-[var(--border)] hover:border-section-ai focus:border-section-ai bg-[var(--bg)] px-4 py-3 text-left transition-colors group">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--text-tertiary)] group-hover:text-section-ai transition-colors">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <span class="text-sm text-[var(--text-tertiary)]">
          想找什么？试试 <span class="font-mono text-[var(--text-secondary)]">RLHF</span> · <span class="font-mono text-[var(--text-secondary)]">茅台</span> · <span class="font-mono text-[var(--text-secondary)]">黄山</span>
        </span>
        <span class="ml-auto text-[10px] font-mono text-[var(--text-tertiary)] border border-[var(--border)] rounded px-1.5 py-0.5">
          /
        </span>
      </button>
    </div>
  </section>

  <script is:inline>
    document.getElementById("home-search-trigger")?.addEventListener("click", () => {
      // SearchModal 在 client:idle 后挂到 window
      const open = window.__openSearch;
      if (typeof open === "function") open();
    });
  </script>

  <!-- ── 精选阅读（首屏内容钩子，3 张大卡）── -->
  {featured.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 mb-12 sm:mb-16">
      <div class="flex items-baseline justify-between mb-5">
        <h2 class="text-lg sm:text-xl font-semibold tracking-tight">精选阅读</h2>
        <span class="text-[11px] uppercase tracking-[0.15em] text-[var(--text-tertiary)] font-mono">FEATURED</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 sm:gap-4">
        {featured.map((p, i) => {
          const sec = p.section;
          const isDg = (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");
          return (
            <a href={pathWithLang(`/${sec}/${p.data.translationKey}`, lang)}
               class={`group relative rounded-2xl bg-gradient-to-br ${sectionGradient[sec]} p-6 sm:p-7 min-h-[200px] flex flex-col justify-between transition-transform hover:scale-[1.02] hover:-translate-y-0.5 animate-rise`}
               style={`animation-delay: ${i * 100}ms`}>
              <div>
                <div class="flex items-center gap-2 mb-3">
                  <span class="w-1.5 h-1.5 rounded-full" style={`background:${sectionAccent[sec]}`}></span>
                  <span class="text-[10px] uppercase tracking-[0.18em] font-mono text-[var(--text-tertiary)]">
                    {sectionLabel[sec]}{isDg ? " · DAILY" : ""}
                  </span>
                </div>
                <h3 class="text-lg sm:text-xl font-semibold leading-snug tracking-tight line-clamp-3"
                    style={`color:${sectionAccent[sec]}`}>
                  {p.data.title}
                </h3>
                {p.data.description && (
                  <p class="mt-2 text-xs sm:text-sm text-[var(--text-secondary)] leading-relaxed line-clamp-2">
                    {p.data.description}
                  </p>
                )}
              </div>
              <div class="mt-4 flex items-center justify-between text-[11px] text-[var(--text-tertiary)] font-mono">
                <time>{p.data.date.toISOString().slice(0, 10)}</time>
                <span class="group-hover:translate-x-1 transition-transform">→</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- ── 四个栏目卡（2×2 圆角灰底，Apple 产品宫格风） ── -->
  <section class="max-w-6xl mx-auto px-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
    <SectionCard href={pathWithLang("/ai", lang)}     title={t("section.ai.title")}     desc={t("section.ai.desc")}     accent="ai"     count={aiOriginal.length}     countLabel="原创" countSecondary={`+ ${aiDigestCount} 期日报`} index={0} />
    <SectionCard href={pathWithLang("/invest", lang)} title={t("section.invest.title")} desc={t("section.invest.desc")} accent="invest" count={investOriginal.length} countLabel="复盘" countSecondary={`+ ${investRecapCount + investDigestCount} 期速览`} index={1} />
    <SectionCard href={pathWithLang("/photo", lang)}  title={t("section.photo.title")}  desc={t("section.photo.desc")}  accent="photo"  count={photoAlbums.length}  countLabel="组" index={2} />
    <SectionCard href={pathWithLang("/hike", lang)}   title={t("section.hike.title")}   desc={t("section.hike.desc")}   accent="hike"   count={hikes.length}        countLabel="条" index={3} />
  </section>

  <!-- ── 主题地图入口（LLM embedding 投影 2D · 让访客感知内容广度） ── -->
  <section class="max-w-6xl mx-auto px-5 mt-8 sm:mt-12">
    <a href={pathWithLang("/explore", lang)}
       class="group block rounded-2xl border border-[var(--border)] hover:border-transparent
              bg-gradient-to-br from-blue-50/60 via-purple-50/40 to-emerald-50/60
              dark:from-blue-950/30 dark:via-purple-950/20 dark:to-emerald-950/30
              hover:shadow-lg transition-all duration-300 overflow-hidden">
      <div class="flex items-center gap-4 sm:gap-6 p-5 sm:p-6">
        <!-- 图标区：3 个色点连线，暗示主题聚类 -->
        <div class="shrink-0 hidden sm:block">
          <svg width="72" height="72" viewBox="0 0 72 72" class="opacity-80 group-hover:scale-110 transition-transform">
            <circle cx="20" cy="24" r="6" fill="#1d4ed8" fill-opacity="0.7"/>
            <circle cx="52" cy="18" r="5" fill="#991b1b" fill-opacity="0.7"/>
            <circle cx="16" cy="52" r="4" fill="#166534" fill-opacity="0.7"/>
            <circle cx="48" cy="50" r="7" fill="#6b21a8" fill-opacity="0.7"/>
            <circle cx="36" cy="34" r="3" fill="currentColor" fill-opacity="0.3"/>
            <line x1="20" y1="24" x2="36" y2="34" stroke="currentColor" stroke-width="1" stroke-opacity="0.2"/>
            <line x1="52" y1="18" x2="36" y2="34" stroke="currentColor" stroke-width="1" stroke-opacity="0.2"/>
            <line x1="16" y1="52" x2="36" y2="34" stroke="currentColor" stroke-width="1" stroke-opacity="0.2"/>
            <line x1="48" y1="50" x2="36" y2="34" stroke="currentColor" stroke-width="1" stroke-opacity="0.2"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--text-tertiary)] font-mono mb-1">
            EMBEDDING · 2D PROJECTION
          </div>
          <h3 class="text-lg sm:text-xl font-semibold tracking-tight group-hover:text-blue-600 transition-colors">
            🗺️ 主题地图 —— 看这站在写什么
          </h3>
          <p class="mt-1.5 text-sm text-[var(--text-secondary)] leading-relaxed">
            所有文章用 LLM embedding 投影到 2D 平面，主题相近的自动靠在一起。
            <span class="text-[var(--text-tertiary)]">RLHF 在哪 · 港股在哪 · 徒步在哪，一眼看到。</span>
          </p>
        </div>
        <span class="shrink-0 text-2xl text-[var(--text-tertiary)] group-hover:translate-x-1 group-hover:text-blue-600 transition-all">→</span>
      </div>
    </a>
  </section>

  <!-- ── 最近更新（极简列表） ── -->
  {latest.length > 0 && (
    <section class="max-w-3xl mx-auto px-5 mt-24 sm:mt-32 pb-24">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">{t("home.latest")}</h2>
        <span class="text-sm text-[var(--text-tertiary)]">{latest.length} 条</span>
      </div>
      <ul class="divide-y divide-[var(--border)]">
        {latest.map((p, i) => (
          <li class="py-4 animate-rise" style={`animation-delay: ${100 + i * 50}ms`}>
            <a href={pathWithLang(`/${p.section}/${p.data.translationKey}`, lang)} class="flex items-center gap-4 group">
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${sectionAccent[p.section]}`}></span>
              <span class="text-xs text-[var(--text-tertiary)] uppercase tracking-wide shrink-0 w-16">{sectionLabel[p.section]}</span>
              <span class="flex-1 truncate text-[15px] group-hover:text-[var(--text)] text-[var(--text-secondary)] transition-colors">{p.data.title}</span>
              <time class="text-xs text-[var(--text-tertiary)] shrink-0 tabular-nums">{p.data.date.toISOString().slice(0, 10)}</time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
