---
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MarketIndicesGrid from "@/components/MarketIndicesGrid";
import LiveHoldings from "@/components/LiveHoldings";
import { useTranslations, pathWithLang } from "@/i18n/ui";

const lang = "zh" as const;
const t = useTranslations(lang);

// ── 读取持仓底表 _holdings.yaml ──
// 用本地极简 YAML 解析（与 scripts/invest-snapshot.ts 风格一致，避免引依赖）。
// 仅支持本文件的固定结构：- key: value
const holdingsPath = path.resolve("./src/content/invest-portfolio/_holdings.yaml");
const rawYaml = fs.readFileSync(holdingsPath, "utf-8");

type Holding = { symbol: string; name: string; shares: number; costAvg: number };
function parseHoldings(text: string): Holding[] {
  const lines = text.split("\n").map(l => l.replace(/#.*$/, ""));
  const out: Holding[] = [];
  let cur: any = null;
  let inHoldings = false;
  for (const line of lines) {
    if (/^holdings:/.test(line)) { inHoldings = true; continue; }
    if (!inHoldings) continue;
    if (/^\S/.test(line) && line.trim()) break; // 出到下一个顶级 key（如 notes:）
    const dash = line.match(/^\s*-\s+symbol:\s*"?([^"]+)"?\s*$/);
    if (dash) {
      if (cur) out.push(cur);
      cur = { symbol: dash[1], name: "", shares: 0, costAvg: 0 };
      continue;
    }
    const kv = line.match(/^\s+(\w+):\s*"?([^"]+)"?\s*$/);
    if (kv && cur) {
      const [, k, v] = kv;
      if (k === "name") cur.name = v;
      else if (k === "shares") cur.shares = Number(v);
      else if (k === "costAvg") cur.costAvg = Number(v);
    }
  }
  if (cur) out.push(cur);
  return out;
}
const holdings: Holding[] = parseHoldings(rawYaml);

// ── 复盘文章 ──
const posts = (await getCollection("invest", (p) => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// ── 历史月度快照 ──
const snapshots = (await getCollection("invest-portfolio"))
  .sort((a, b) => a.data.period.localeCompare(b.data.period));
const latestPeriod = snapshots[snapshots.length - 1]?.data.period;
---

<BaseLayout title={t("section.invest.title")} description={t("section.invest.desc")}>
  <section class="max-w-5xl mx-auto px-5 pt-12 pb-6">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight" style="color:#991b1b">{t("section.invest.title")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{t("section.invest.desc")}</p>
  </section>

  <!-- A · 今日大盘 -->
  <section class="max-w-5xl mx-auto px-5 pb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">今日大盘</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <MarketIndicesGrid client:load />
  </section>

  <!-- B · 我的持仓（实时基金估值） -->
  <section class="max-w-5xl mx-auto px-5 pb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">我的持仓（估算）</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <LiveHoldings holdings={holdings} client:load />
  </section>

  <p class="max-w-5xl mx-auto px-5 mt-4 text-[11px] text-[var(--text-tertiary)] leading-relaxed">
    本页行情由东方财富 / 天天基金等公开接口提供，仅供参考；持仓份额与成本为占位 / 学习日志，<strong>不构成任何投资建议</strong>。
    历史业绩不代表未来表现，市场有风险，入市需谨慎。
  </p>

  <!-- 历史月度快照（保留作为复盘记录入口） -->
  {latestPeriod && (
    <section class="max-w-5xl mx-auto px-5 mt-10">
      <h2 class="text-base font-semibold tracking-tight mb-2">月度快照</h2>
      <p class="text-xs text-[var(--text-tertiary)] mb-3">最新快照：{latestPeriod}（每月由 cron 写入 <code>invest-portfolio/{`{YYYY-MM}`}.yaml</code>）</p>
    </section>
  )}

  <!-- 复盘文章 -->
  <section class="max-w-5xl mx-auto px-5 mt-10">
    <h2 class="text-xl font-semibold mb-4">复盘</h2>
    {posts.length === 0 ? <p class="text-[var(--text-tertiary)]">还没有复盘文章</p> : (
      <ul class="divide-y divide-[var(--border)]">
        {posts.map((p) => (
          <li class="py-4">
            <a href={pathWithLang(`/invest/${p.data.translationKey}`, lang)} class="block group">
              <div class="text-xs text-[var(--text-tertiary)] mb-1"><time>{p.data.date.toISOString().slice(0, 10)}</time></div>
              <h3 class="text-base font-semibold group-hover:text-section-invest transition-colors">{p.data.title}</h3>
              {p.data.description && <p class="mt-1 text-sm text-[var(--text-secondary)]">{p.data.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
