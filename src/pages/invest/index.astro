---
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import MarketIndicesGrid from "@/components/MarketIndicesGrid";
import LiveHoldings from "@/components/LiveHoldings";
import StockSpotlight from "@/components/StockSpotlight";
import SectorRanking from "@/components/SectorRanking";
import MarketSentiment from "@/components/MarketSentiment";
import { useTranslations, pathWithLang } from "@/i18n/ui";
import { extractDigestHighlights } from "@/lib/digest-highlights";

// ── Phase C: AI 科创聚焦 + 创业板风向 ──
const aiKechuangStocks = [
  { secid: "1.688981", display_name: "中芯国际",   note: "晶圆代工龙头" },
  { secid: "1.688256", display_name: "寒武纪",     note: "AI 加速芯片" },
  { secid: "1.688041", display_name: "海光信息",   note: "国产 CPU / DCU" },
  { secid: "1.601138", display_name: "工业富联",   note: "AI 服务器代工" },
  { secid: "0.300308", display_name: "中际旭创",   note: "AI 服务器光模块" },
  { secid: "0.002371", display_name: "北方华创",   note: "半导体设备" },
  { secid: "0.300474", display_name: "景嘉微",     note: "国产 GPU" },
  { secid: "0.002463", display_name: "沪电股份",   note: "AI 服务器 PCB" },
  { secid: "1.688008", display_name: "澜起科技",   note: "内存接口芯片" },
  { secid: "0.300782", display_name: "卓胜微",     note: "射频前端" },
];

const chinextStocks = [
  { secid: "0.300750", display_name: "宁德时代",   note: "动力电池" },
  { secid: "0.300760", display_name: "迈瑞医疗",   note: "医疗器械" },
  { secid: "0.300059", display_name: "东方财富",   note: "互联网券商" },
  { secid: "0.300124", display_name: "汇川技术",   note: "工业自动化" },
  { secid: "0.300274", display_name: "阳光电源",   note: "光伏逆变器" },
  { secid: "0.300033", display_name: "同花顺",     note: "金融科技" },
  { secid: "0.300999", display_name: "金龙鱼",     note: "粮油食品" },
  { secid: "0.300015", display_name: "爱尔眼科",   note: "眼科连锁" },
  { secid: "0.300450", display_name: "先导智能",   note: "锂电设备" },
  { secid: "0.300866", display_name: "安克创新",   note: "消费电子出海" },
];

const lang = "zh" as const;
const t = useTranslations(lang);

// ── 读取持仓底表 _holdings.yaml ──
// 用本地极简 YAML 解析（与 scripts/invest-snapshot.ts 风格一致，避免引依赖）。
// 仅支持本文件的固定结构：- key: value
const holdingsPath = path.resolve("./src/content/invest-portfolio/_holdings.yaml");
const rawYaml = fs.readFileSync(holdingsPath, "utf-8");

type Holding = { symbol: string; name: string; shares: number; costAvg: number };
function parseHoldings(text: string): Holding[] {
  const lines = text.split("\n").map(l => l.replace(/#.*$/, ""));
  const out: Holding[] = [];
  let cur: any = null;
  let inHoldings = false;
  for (const line of lines) {
    if (/^holdings:/.test(line)) { inHoldings = true; continue; }
    if (!inHoldings) continue;
    if (/^\S/.test(line) && line.trim()) break; // 出到下一个顶级 key（如 notes:）
    const dash = line.match(/^\s*-\s+symbol:\s*"?([^"]+)"?\s*$/);
    if (dash) {
      if (cur) out.push(cur);
      cur = { symbol: dash[1], name: "", shares: 0, costAvg: 0 };
      continue;
    }
    const kv = line.match(/^\s+(\w+):\s*"?([^"]+)"?\s*$/);
    if (kv && cur) {
      const [, k, v] = kv;
      if (k === "name") cur.name = v;
      else if (k === "shares") cur.shares = Number(v);
      else if (k === "costAvg") cur.costAvg = Number(v);
    }
  }
  if (cur) out.push(cur);
  return out;
}
const holdings: Holding[] = parseHoldings(rawYaml);

// ── 复盘文章（原创） + 自动日报分流 ──
const allInvest = (await getCollection("invest", (p) => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const isDigest = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");
const isMarketRecap = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("market-recap") || p.data.translationKey.startsWith("market-recap-");
const isReview = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("review") || p.data.translationKey.includes("review");
// 复盘 = 只显示 review tag（真正的原创月度思考），排除自动 market-recap
const posts = allInvest.filter(isReview);
const marketRecaps = allInvest.filter(isMarketRecap).slice(0, 3);  // 展示最近 3 篇日报
const digests = allInvest.filter(isDigest);
const latestDigest = digests[0];

// ── 历史月度快照 ──
const snapshots = (await getCollection("invest-portfolio"))
  .sort((a, b) => a.data.period.localeCompare(b.data.period));
const latestPeriod = snapshots[snapshots.length - 1]?.data.period;

// ── 看板 SSR 兜底快照：构建时读 src/data/wind-market-latest.json ──
// 由服务器 Wind cron (15:30 BJT) 推到 repo。无 JS / 爬虫看到这份；客户端 JS 进来后 fetch /api/market 覆盖。
let initialIndices: any[] = [];
let initialSectors: any = undefined;
let initialSentiment: any = undefined;
let snapshotAsOf: string | undefined;
try {
  const raw = fs.readFileSync(path.resolve("./src/data/wind-market-latest.json"), "utf-8");
  const wind = JSON.parse(raw);
  snapshotAsOf = wind.asOf || wind.date;

  initialIndices = (wind.indices || []).map((i: any) => ({
    code: i.code,
    name: i.name,
    market: i.code?.endsWith?.(".HK") ? "HK" :
            (i.code?.endsWith?.(".SH") || i.code?.endsWith?.(".SZ")) ? "A" : "US",
    price: i.price,
    change: i.change_amount,
    change_pct: i.change_pct,
  }));

  // 板块涨跌排行：Wind 的 sectors 是已按 change_pct 排序的，取前 10 / 后 10
  const sectors = (wind.sectors || []).map((s: any) => ({
    code: s.code, name: s.name, price: null, change_pct: s.change_pct,
  }));
  const up = [...sectors].filter((s) => (s.change_pct ?? 0) > 0).slice(0, 10);
  const down = [...sectors].filter((s) => (s.change_pct ?? 0) < 0).sort((a, b) => (a.change_pct ?? 0) - (b.change_pct ?? 0)).slice(0, 10);
  if (sectors.length > 0) {
    initialSectors = { ok: true, ts: 0, total: sectors.length, top_up: up, top_down: down };
  }

  // 涨跌停家数
  if (wind.sentiment && (wind.sentiment.limit_up != null || wind.sentiment.limit_down != null)) {
    initialSentiment = {
      ok: true, ts: 0,
      breadth: {
        limit_up: wind.sentiment.limit_up ?? 0,
        limit_down: wind.sentiment.limit_down ?? 0,
      },
    };
  }
} catch { /* 没快照文件就走纯客户端 */ }
---

<BaseLayout title={t("section.invest.title")} description={t("section.invest.desc")}>
  <section class="max-w-5xl mx-auto px-5 pt-12 pb-6">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight" style="color:#991b1b">{t("section.invest.title")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{t("section.invest.desc")}</p>
  </section>

  <!-- NEW · Wind 看板入口（A 股 + 港股 + ETF 三因子） -->
  <section class="max-w-5xl mx-auto px-5 pb-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <a href={pathWithLang("/invest/market", lang)}
         class="group block border border-[var(--border)] rounded-lg p-4 hover:border-section-invest transition-colors">
        <div class="text-base font-semibold tracking-tight group-hover:text-section-invest">
          📊 A 股市场看板 →
        </div>
        <p class="mt-1 text-sm text-[var(--text-secondary)]">
          A 股观察池 · 主力 · 涨幅榜 · 申万板块
        </p>
        <span class="mt-2 inline-block text-[10px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind · 每小时刷新</span>
      </a>
      <a href={pathWithLang("/invest/hk-market", lang)}
         class="group block border border-[var(--border)] rounded-lg p-4 hover:border-section-invest transition-colors">
        <div class="text-base font-semibold tracking-tight group-hover:text-section-invest">
          🇭🇰 港股市场看板 →
        </div>
        <p class="mt-1 text-sm text-[var(--text-secondary)]">
          港股观察池 · 恒生指数 · 涨幅榜
        </p>
        <span class="mt-2 inline-block text-[10px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind · 每小时刷新</span>
      </a>
      <a href={pathWithLang("/invest/etf", lang)}
         class="group block border border-[var(--border)] rounded-lg p-4 hover:border-section-invest transition-colors">
        <div class="text-base font-semibold tracking-tight group-hover:text-section-invest">
          🛡️ ETF 三因子监测 →
        </div>
        <p class="mt-1 text-sm text-[var(--text-secondary)]">
          国家队 ETF 资金信号 · 量能 · 方向 · 份额
        </p>
        <span class="mt-2 inline-block text-[10px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">akshare · 每日 19:30</span>
      </a>
    </div>
  </section>

  <!-- A · 今日大盘 -->
  <section class="max-w-5xl mx-auto px-5 pb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">今日大盘</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <MarketIndicesGrid initialIndices={initialIndices} client:load />
  </section>

  <!-- D · 市场情绪：成交额 / 涨跌家数 / 涨停跌停 -->
  <section class="max-w-5xl mx-auto px-5 pb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">市场情绪</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <MarketSentiment initialData={initialSentiment} client:visible />
  </section>

  <!-- B · 我的持仓（实时基金估值） -->
  <section class="max-w-5xl mx-auto px-5 pb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">我的持仓（估算）</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <LiveHoldings holdings={holdings} client:load />
  </section>

  <!-- C1 · AI 科创聚焦 -->
  <section class="max-w-5xl mx-auto px-5 pb-8 mt-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">🤖 AI · 科创聚焦</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <StockSpotlight stocks={aiKechuangStocks} client:visible />
  </section>

  <!-- C2 · 创业板风向 -->
  <section class="max-w-5xl mx-auto px-5 pb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">🚀 创业板风向</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <StockSpotlight stocks={chinextStocks} client:visible />
  </section>

  <!-- C3 · 行业板块涨跌榜 -->
  <section class="max-w-5xl mx-auto px-5 pb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold tracking-tight">📊 行业板块涨跌</h2>
      <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Live</span>
    </div>
    <SectorRanking initialData={initialSectors} client:visible />
  </section>

  <p class="max-w-5xl mx-auto px-5 mt-4 text-[11px] text-[var(--text-tertiary)] leading-relaxed">
    本页行情由东方财富 / 天天基金等公开接口提供，仅供参考；持仓份额与成本为占位 / 学习日志，<strong>不构成任何投资建议</strong>。
    历史业绩不代表未来表现，市场有风险，入市需谨慎。
  </p>

  <!-- 历史月度快照（保留作为复盘记录入口） -->
  {latestPeriod && (
    <section class="max-w-5xl mx-auto px-5 mt-10">
      <h2 class="text-base font-semibold tracking-tight mb-2">月度快照</h2>
      <p class="text-xs text-[var(--text-tertiary)] mb-3">最新快照：{latestPeriod}（每月由 cron 写入 <code>invest-portfolio/{`{YYYY-MM}`}.yaml</code>）</p>
    </section>
  )}

  <!-- ── 区一：月度复盘（原创，慢速） ── -->
  <section class="max-w-5xl mx-auto px-5 mt-12">
    <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-[var(--border)]">
      <h2 class="text-lg font-semibold tracking-tight">🧠 月度复盘</h2>
      <span class="text-xs text-[var(--text-tertiary)] font-mono">
        {posts.length} 篇 · 每月一次
      </span>
    </div>
    {posts.length === 0 ? (
      <div class="py-8 text-center text-sm text-[var(--text-tertiary)]">
        <p>本月复盘还在路上。</p>
        <p class="mt-1 text-xs">目标：每月一次系统总结 —— 仓位调整 / 判断对错 / 下月计划。</p>
      </div>
    ) : (
      <>
        <ul class="divide-y divide-[var(--border)]">
          {posts.map((p) => {
            const highlights = extractDigestHighlights(p.body, 3);
            return (
              <li class="py-4">
                <div class="text-xs text-[var(--text-tertiary)] mb-1"><time>{p.data.date.toISOString().slice(0, 10)}</time></div>
                <h3 class="text-base font-semibold">
                  <a href={pathWithLang(`/invest/${p.data.translationKey}`, lang)}
                     class="hover:text-section-invest transition-colors">
                    {p.data.title}
                  </a>
                </h3>
                {p.data.description && <p class="mt-1 text-sm text-[var(--text-secondary)]">{p.data.description}</p>}
                {highlights.length > 0 && (
                  <ul class="mt-2 space-y-0.5">
                    {highlights.map(h => (
                      <li class="text-xs text-[var(--text-tertiary)] line-clamp-1">· {h}</li>
                    ))}
                  </ul>
                )}
              </li>
            );
          })}
        </ul>
        {posts.length < 4 && (
          <p class="mt-4 text-xs text-[var(--text-tertiary)] italic">
            月度复盘产出较慢，是"检查判断"的强制反思机制。下方 <a href={pathWithLang("/invest/digest", lang)} class="underline hover:text-section-invest">投资资讯日报</a> 与 <a href="#market-recap" class="underline hover:text-section-invest">每日市场速览</a> 是自动化产出的高信噪比数据流。
          </p>
        )}
      </>
    )}
  </section>

  <!-- ── 区二：每日市场速览（cron 自动） ── -->
  {marketRecaps.length > 0 && (
    <section id="market-recap" class="max-w-5xl mx-auto px-5 mt-12">
      <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-[var(--border)]">
        <h2 class="text-lg font-semibold tracking-tight">📈 每日市场速览</h2>
        <span class="text-xs text-[var(--text-tertiary)] font-mono">
          cron 每日 15:30 · Wind 数据
        </span>
      </div>
      <ul class="divide-y divide-[var(--border)]">
        {marketRecaps.map(r => (
          <li class="py-3">
            <a href={pathWithLang(`/invest/${r.data.translationKey}`, lang)}
               class="group flex items-baseline justify-between gap-3 hover:text-section-invest">
              <div class="min-w-0 flex-1">
                <span class="text-sm font-medium">{r.data.title}</span>
                {r.data.description && (
                  <p class="mt-0.5 text-xs text-[var(--text-tertiary)] line-clamp-1">{r.data.description}</p>
                )}
              </div>
              <time class="text-xs text-[var(--text-tertiary)] font-mono shrink-0">{r.data.date.toISOString().slice(0, 10)}</time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- 自动日报入口卡（投资资讯日报） -->
  {digests.length > 0 && (
    <section class="max-w-5xl mx-auto px-5 mt-12 pb-12">
      <a href={pathWithLang("/invest/digest", lang)}
         class="group block border border-[var(--border)] rounded-xl p-5 hover:border-section-invest transition-colors">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.15em] text-[var(--text-tertiary)] font-mono mb-1">
              Auto Digest
            </div>
            <h3 class="text-base font-semibold group-hover:text-section-invest transition-colors">
              投资资讯日报 · 自动归档 →
            </h3>
            <p class="mt-1 text-sm text-[var(--text-secondary)] line-clamp-1">
              cron 每日 08:00 抓取同花顺 + 东方财富 + Yahoo Finance，AI 改写
            </p>
          </div>
          <div class="text-right shrink-0">
            <div class="text-2xl font-semibold tabular-nums">{digests.length}</div>
            <div class="text-[11px] uppercase tracking-wider text-[var(--text-tertiary)]">期</div>
          </div>
        </div>
        {latestDigest && (
          <div class="mt-3 pt-3 border-t border-[var(--border)] text-xs text-[var(--text-tertiary)]">
            最新一期：{latestDigest.data.date.toISOString().slice(0, 10)} · {latestDigest.data.description}
          </div>
        )}
      </a>
    </section>
  )}
</BaseLayout>
