---
/**
 * /invest/market — Wind 市场深度看板
 *
 * 数据源：src/data/wind-market-latest.json
 *   由 stock_pusher 每个交易日 15:30 收盘后通过 Wind 拉取，git push 触发 CI 部署
 *
 * 不同于 /invest 主页（动态实时调东方财富 / 天天基金），本页是每日一次的静态快照，
 * 重点展示 Wind 独家字段：5 日/20 日涨跌、近 5 日主力净流入、申万一级板块、要闻摘要等。
 */
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";

const lang = "zh" as const;
const t = useTranslations(lang);

// ── 读 Wind 快照 ──
type WindIndex = { code: string; name: string; price: number; change_amount: number; change_pct: number; emoji: string };
type WindStock = {
  code: string; name: string; price: number; yesterday_close: number; open: number; high: number; low: number;
  amount_yi: number; change_pct: number; amplitude: number; turnover: number;
  chg_5d: number; chg_20d: number; chg_ytd: number;
  main_net_5d_yi: number; main_net_5d_pct: number; emoji: string; error?: string;
};
type WindHot = { name: string; code: string; price: number; change_pct: number; is_limit_up: boolean; limit: number; error?: string };
type WindSector = { code: string; name: string; change_pct: number; lead_stock: string; emoji: string; error?: string };
type WindNews = { title: string; date: string; snippet: string; error?: string };
type Snapshot = {
  asOf: string;
  date: string;
  indices: WindIndex[];
  sentiment: { limit_up?: number; limit_down?: number; main_flow_yi?: number; error?: string };
  watchlist: WindStock[];
  hotStocks: WindHot[];
  sectors: WindSector[];
  news: WindNews[];
};

const snapshotPath = path.resolve("./src/data/wind-market-latest.json");
let snap: Snapshot | null = null;
try {
  snap = JSON.parse(fs.readFileSync(snapshotPath, "utf-8"));
} catch {
  snap = null;
}

// 按涨跌幅降序排自选股
const watchlistSorted = snap?.watchlist
  ? [...snap.watchlist].sort((a, b) =>
      (a.error ? 1 : 0) - (b.error ? 1 : 0) || (b.change_pct ?? 0) - (a.change_pct ?? 0)
    )
  : [];

// 判断哪些股票有 detail 页
let detailCodes = new Set<string>();
try {
  const detailsRaw = fs.readFileSync(path.resolve("./src/data/wind-stock-details.json"), "utf-8");
  const dets = JSON.parse(detailsRaw);
  detailCodes = new Set(Object.keys(dets.stocks || {}));
} catch { /* no details file yet */ }

// ── 历史归档列表 ──
const recaps = (await getCollection("invest", (p) =>
  p.data.lang === lang && !p.data.draft && p.data.translationKey.startsWith("market-recap-")
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 工具：百度搜索链接（为新闻标题加可点击的兜底）
function baiduSearch(q: string): string {
  return `https://www.baidu.com/s?wd=${encodeURIComponent(q)}`;
}

function fmtPrice(v: number | null | undefined): string {
  if (v == null || !Number.isFinite(Number(v)) || Number(v) === 0) return "--";
  return Number(v).toFixed(2);
}
function fmtPct(v: number | null | undefined): string {
  if (v == null) return "--";
  const n = Number(v);
  if (!Number.isFinite(n)) return "--";
  return `${n >= 0 ? "+" : ""}${n.toFixed(2)}%`;
}
function colorClass(v: number | null | undefined): string {
  if (v == null || !Number.isFinite(Number(v))) return "text-[var(--text-tertiary)]";
  const n = Number(v);
  if (n > 0) return "text-red-600 dark:text-red-400";
  if (n < 0) return "text-emerald-600 dark:text-emerald-400";
  return "text-[var(--text-tertiary)]";
}
function fmtAsOf(iso: string | undefined): string {
  if (!iso) return "—";
  try {
    const d = new Date(iso);
    return d.toLocaleString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit", hour: "2-digit", minute: "2-digit", hour12: false });
  } catch { return iso; }
}
---

<BaseLayout
  title="Wind 市场深度看板"
  description="A 股观察池、涨幅榜、申万一级板块、市场情绪、财经要闻 · Wind 数据每日 15:30 更新"
>
  <!-- 页头 -->
  <section class="max-w-5xl mx-auto px-5 pt-12 pb-4">
    <a href={pathWithLang("/invest", lang)} class="text-sm text-section-invest hover:underline">← {t("section.invest.title")}</a>
    <h1 class="mt-3 font-serif text-4xl sm:text-5xl leading-[0.95] tracking-tight" style="color:#991b1b">
      Wind 市场深度看板
    </h1>
    <p class="mt-2 text-[var(--text-secondary)]">
      A 股观察池 · 涨幅榜 · 申万一级板块 · 市场情绪 · 财经要闻
    </p>
    <p class="mt-2 text-xs text-[var(--text-tertiary)]">
      数据来源 <strong>Wind 万得</strong> · 每个交易日 15:30 收盘后自动更新
      {snap && (<> · 最新 <time>{fmtAsOf(snap.asOf)}</time></>)}
    </p>
  </section>

  {!snap && (
    <section class="max-w-5xl mx-auto px-5 py-12 text-center">
      <p class="text-[var(--text-secondary)]">⏳ 还没有 Wind 快照数据。</p>
      <p class="mt-2 text-xs text-[var(--text-tertiary)]">
        等本机 stock_pusher 在交易日 15:30 收盘后生成并 git push 即可。
      </p>
    </section>
  )}

  {snap && (
    <>
      <!-- 1. 大盘 -->
      <section class="max-w-5xl mx-auto px-5 pb-8">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight">📈 大盘</h2>
          <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[var(--text-tertiary)] text-xs">
              <tr><th class="text-left py-2">指数</th><th class="text-right">点位</th><th class="text-right">涨跌</th></tr>
            </thead>
            <tbody class="divide-y divide-[var(--border)]">
              {snap.indices.map((idx) => (
                <tr class="hover:bg-[var(--surface-2)]">
                  <td class="py-2.5">
                    <span>{idx.emoji}</span> <span class="font-medium">{idx.name}</span>
                  </td>
                  <td class="text-right font-mono">{fmtPrice(idx.price)}</td>
                  <td class={`text-right font-mono ${colorClass(idx.change_pct)}`}>
                    {idx.change_amount >= 0 ? "+" : ""}{idx.change_amount?.toFixed(2)} ({fmtPct(idx.change_pct)})
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- 2. 市场情绪 -->
      <section class="max-w-5xl mx-auto px-5 pb-8">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight">🌡️ 市场情绪</h2>
          <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="border border-[var(--border)] rounded-lg p-4">
            <div class="text-xs text-[var(--text-tertiary)]">🚀 涨停家数</div>
            <div class="mt-1 text-2xl font-semibold text-red-600 dark:text-red-400 font-mono">
              {snap.sentiment?.limit_up ?? "—"}
            </div>
          </div>
          <div class="border border-[var(--border)] rounded-lg p-4">
            <div class="text-xs text-[var(--text-tertiary)]">💥 跌停家数</div>
            <div class="mt-1 text-2xl font-semibold text-emerald-600 dark:text-emerald-400 font-mono">
              {snap.sentiment?.limit_down ?? "—"}
            </div>
          </div>
          <div class="border border-[var(--border)] rounded-lg p-4">
            <div class="text-xs text-[var(--text-tertiary)]">💰 主力资金净流入</div>
            <div class={`mt-1 text-2xl font-semibold font-mono ${colorClass(snap.sentiment?.main_flow_yi)}`}>
              {snap.sentiment?.main_flow_yi != null
                ? `${snap.sentiment.main_flow_yi >= 0 ? "+" : ""}${snap.sentiment.main_flow_yi.toFixed(1)} 亿`
                : "—"}
            </div>
          </div>
        </div>
      </section>

      <!-- 3. A 股观察池 -->
      <section class="max-w-5xl mx-auto px-5 pb-8">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight">🔍 A 股观察池</h2>
          <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind · 多周期 · 主力</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[var(--text-tertiary)] text-xs">
              <tr>
                <th class="text-left py-2">股票</th>
                <th class="text-right">现价</th>
                <th class="text-right">今日</th>
                <th class="text-right">5日</th>
                <th class="text-right">20日</th>
                <th class="text-right">年初至今</th>
                <th class="text-right">近5日主力(亿)</th>
                <th class="text-right">详情</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--border)]">
              {watchlistSorted.map((s) => s.error ? (
                <tr><td colspan="8" class="py-2.5 text-xs text-[var(--text-tertiary)]">⚠️ {s.code}: {s.error}</td></tr>
              ) : (
                <tr class="hover:bg-[var(--surface-2)]">
                  <td class="py-2.5">
                    <span>{s.emoji}</span>
                    <span class="ml-1 font-medium">{s.name}</span>
                    <span class="ml-2 text-[10px] font-mono text-[var(--text-tertiary)]">{s.code}</span>
                  </td>
                  <td class="text-right font-mono">{fmtPrice(s.price)}</td>
                  <td class={`text-right font-mono font-semibold ${colorClass(s.change_pct)}`}>{fmtPct(s.change_pct)}</td>
                  <td class={`text-right font-mono ${colorClass(s.chg_5d)}`}>{fmtPct(s.chg_5d)}</td>
                  <td class={`text-right font-mono ${colorClass(s.chg_20d)}`}>{fmtPct(s.chg_20d)}</td>
                  <td class={`text-right font-mono ${colorClass(s.chg_ytd)}`}>{fmtPct(s.chg_ytd)}</td>
                  <td class={`text-right font-mono ${colorClass(s.main_net_5d_yi)}`}>
                    {s.main_net_5d_yi != null ? `${s.main_net_5d_yi >= 0 ? "+" : ""}${s.main_net_5d_yi.toFixed(1)}` : "--"}
                  </td>
                  <td class="text-right">
                    {detailCodes.has(s.code) ? (
                      <a href={pathWithLang(`/invest/stock/${s.code}`, lang)} class="text-section-invest hover:underline text-xs">详情→</a>
                    ) : <span class="text-[10px] text-[var(--text-tertiary)]">—</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-[11px] text-[var(--text-tertiary)] leading-relaxed">
          观察池来自 <code class="text-[10px]">stock_pusher/.env STOCK_CODES</code>，按今日涨跌幅降序。<strong>仅作研究记录，不构成投资建议。</strong>
        </p>
      </section>

      <!-- 4. 涨幅榜 -->
      <section class="max-w-5xl mx-auto px-5 pb-8">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight">🔥 涨幅榜 TOP5</h2>
          <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind · 沪深 A 股</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[var(--text-tertiary)] text-xs">
              <tr><th class="text-left py-2 w-10">#</th><th class="text-left">股票</th><th class="text-right">现价</th><th class="text-right">涨幅</th></tr>
            </thead>
            <tbody class="divide-y divide-[var(--border)]">
              {snap.hotStocks.map((h, i) => h.error ? (
                <tr><td colspan="4" class="py-2.5 text-xs text-[var(--text-tertiary)]">⚠️ {h.error}</td></tr>
              ) : (
                <tr class="hover:bg-[var(--surface-2)]">
                  <td class="py-2.5 text-[var(--text-tertiary)] font-mono">{i + 1}</td>
                  <td>
                    <span class="font-medium">{h.name}</span>
                    <span class="ml-2 text-[10px] font-mono text-[var(--text-tertiary)]">{h.code}</span>
                  </td>
                  <td class="text-right font-mono">{fmtPrice(h.price)}</td>
                  <td class={`text-right font-mono font-semibold ${colorClass(h.change_pct)}`}>
                    {fmtPct(h.change_pct)}{h.is_limit_up && <span class="ml-1">🚀</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- 5. 板块涨跌 -->
      <section class="max-w-5xl mx-auto px-5 pb-8">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight">💰 热门板块 TOP5</h2>
          <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind · 申万一级</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[var(--text-tertiary)] text-xs">
              <tr><th class="text-left py-2">板块</th><th class="text-right">涨幅</th><th class="text-left pl-4">领涨股</th></tr>
            </thead>
            <tbody class="divide-y divide-[var(--border)]">
              {snap.sectors.map((s) => s.error ? (
                <tr><td colspan="3" class="py-2.5 text-xs text-[var(--text-tertiary)]">⚠️ {s.error}</td></tr>
              ) : (
                <tr class="hover:bg-[var(--surface-2)]">
                  <td class="py-2.5"><span>{s.emoji}</span> <span class="font-medium">{s.name}</span></td>
                  <td class={`text-right font-mono font-semibold ${colorClass(s.change_pct)}`}>{fmtPct(s.change_pct)}</td>
                  <td class="pl-4 text-[var(--text-secondary)]">{s.lead_stock || "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- 6. 今日要闻 -->
      <section class="max-w-5xl mx-auto px-5 pb-8">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-base font-semibold tracking-tight">📰 今日要闻 TOP3</h2>
          <span class="text-[11px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind</span>
        </div>
        <ol class="space-y-3 list-decimal list-inside">
          {snap.news.map((n) => n.error ? (
            <li class="text-xs text-[var(--text-tertiary)]">⚠️ {n.error}</li>
          ) : (
            <li class="border border-[var(--border)] rounded-lg p-3">
              <a href={baiduSearch(n.title)} target="_blank" rel="noopener noreferrer"
                 class="font-medium text-section-invest hover:underline">
                {n.title}
              </a>
              <span class="ml-1.5 text-[10px] font-mono uppercase tracking-wider text-[var(--text-tertiary)] align-middle"
                    title="Wind 不返回原文 URL，标题跳转到百度搜索">
                ↗ 搜索
              </span>
              {n.date && <span class="ml-2 text-[10px] font-mono text-[var(--text-tertiary)]">{n.date}</span>}
              {n.snippet && (
                <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed line-clamp-3" title={n.snippet}>
                  {n.snippet}…
                </p>
              )}
            </li>
          ))}
        </ol>
      </section>
    </>
  )}

  <!-- 7. 历史归档 -->
  {recaps.length > 0 && (
    <section class="max-w-5xl mx-auto px-5 pt-2 pb-12">
      <h2 class="text-base font-semibold tracking-tight mb-3">📚 历史日报归档</h2>
      <ul class="divide-y divide-[var(--border)]">
        {recaps.map((p) => (
          <li class="py-3">
            <div class="flex items-baseline justify-between gap-3">
              <div>
                <a href={pathWithLang(`/invest/${p.data.translationKey}`, lang)}
                   class="font-medium hover:text-section-invest transition-colors">
                  {p.data.title}
                </a>
                {p.data.description && (
                  <p class="mt-0.5 text-xs text-[var(--text-secondary)]">{p.data.description}</p>
                )}
              </div>
              <time class="text-xs text-[var(--text-tertiary)] font-mono shrink-0">{p.data.date.toISOString().slice(0, 10)}</time>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
