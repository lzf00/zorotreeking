---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";

const lang = "zh" as const;
const t = useTranslations(lang);
const hikes = (await getCollection("hike", (p) => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const diffLabel = { easy: "轻松", moderate: "中等", hard: "困难", expert: "专家" };
const diffColor = {
  easy: "bg-green-500/10 text-green-600",
  moderate: "bg-amber-500/10 text-amber-600",
  hard: "bg-orange-500/10 text-orange-600",
  expert: "bg-red-500/10 text-red-600",
};
---

<BaseLayout title={t("section.hike.title")} description={t("section.hike.desc")}>
  <section class="max-w-3xl mx-auto px-5 pt-12 pb-6">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight" style="color:#166534">{t("section.hike.title")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{t("section.hike.desc")}</p>
  </section>
  <section class="max-w-3xl mx-auto px-5">
    {hikes.length === 0 ? <p class="py-12 text-center text-[var(--text-tertiary)]">还没有路线</p> : (
      <ul class="divide-y divide-[var(--border)]">
        {hikes.map((h) => (
          <li class="py-5">
            <div class="flex items-center gap-2 text-xs text-[var(--text-tertiary)] mb-1.5">
              <time>{h.data.date.toISOString().slice(0, 10)}</time>
              <span>·</span>
              <span>{h.data.location}</span>
              <span class:list={["px-2 py-0.5 rounded-full", diffColor[h.data.difficulty]]}>{diffLabel[h.data.difficulty]}</span>
            </div>
            <h2 class="text-lg font-semibold">
              <a href={pathWithLang(`/hike/${h.data.translationKey}`, lang)}
                 class="hover:text-section-hike transition-colors">
                {h.data.title}
              </a>
            </h2>
            <div class="mt-2 flex items-center gap-4 text-sm text-[var(--text-secondary)]">
              {h.data.distanceKm != null && <span>📏 {h.data.distanceKm} km</span>}
              {h.data.elevationGainM != null && <span>⛰️ +{h.data.elevationGainM} m</span>}
              {h.data.durationHours != null && <span>⏱ {h.data.durationHours} h</span>}
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
