---
/**
 * /explore 主题地图：把所有文章按 LLM embedding 投影到 2D 平面，
 * 视觉上看到内容的"主题聚类"。
 *
 * - 用豆包 embedding 算的 2048 维向量
 * - PCA 投影到 2D（src/lib/pca.ts，build 时跑约 50ms）
 * - 每个点是一篇文章，颜色对应 collection（AI 蓝 / Invest 红 / Hike 绿）
 * - hover 显示标题，click 跳转文章
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import embeddingsData from "@/data/embeddings.json";
import { projectTo2D } from "@/lib/pca";

interface CacheItem { hash: string; vec: number[] }
const cache = embeddingsData as { items?: Record<string, CacheItem> };
const itemsObj = cache.items ?? {};

// 拿所有文章 metadata
const [ai, invest, hike] = await Promise.all([
  getCollection("ai", (p) => p.data.lang === "zh" && !p.data.draft),
  getCollection("invest", (p) => p.data.lang === "zh" && !p.data.draft),
  getCollection("hike", (p) => p.data.lang === "zh" && !p.data.draft),
]);
type Meta = { collection: string; key: string; title: string; date: Date; isDigest: boolean };
const metaMap = new Map<string, Meta>();
const all = [
  ...ai.map((p) => ({ ...p, collection: "ai" })),
  ...invest.map((p) => ({ ...p, collection: "invest" })),
  ...hike.map((p) => ({ ...p, collection: "hike" })),
];
for (const p of all) {
  const isDigest = (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");
  metaMap.set(`${p.collection}/${p.data.translationKey}`, {
    collection: p.collection, key: p.data.translationKey, title: p.data.title,
    date: p.data.date, isDigest,
  });
}

// 只保留 embeddings 里有的 + 有 metadata 的
const valid: Record<string, CacheItem> = {};
for (const [k, v] of Object.entries(itemsObj)) {
  if (metaMap.has(k) && v.vec?.length > 0) valid[k] = v;
}

const points = projectTo2D(valid);

// 显式规格：SVG viewBox -1.05..1.05，留 5% 边距
const VBW = 100, VBH = 100, PAD = 6;
function toSvg(x: number, y: number): { cx: number; cy: number } {
  return {
    cx: PAD + ((x + 1) / 2) * (VBW - 2 * PAD),
    cy: PAD + ((1 - y) / 2) * (VBH - 2 * PAD), // y 翻转：屏幕 y 向下
  };
}

const colorMap: Record<string, string> = {
  ai: "#1d4ed8",
  invest: "#991b1b",
  hike: "#166534",
};

const stats = {
  total: points.length,
  ai: points.filter((p) => p.key.startsWith("ai/")).length,
  invest: points.filter((p) => p.key.startsWith("invest/")).length,
  hike: points.filter((p) => p.key.startsWith("hike/")).length,
};
---

<BaseLayout title="主题地图 · Explore"
            description={`${stats.total} 篇文章的语义距离投影。AI 蓝 · 投资 红 · 徒步 绿`}>
  <article class="max-w-4xl mx-auto px-6 sm:px-8 pt-12 sm:pt-20 pb-24">

    <header class="mb-10">
      <div class="text-[11px] uppercase tracking-[0.2em] text-zinc-500 font-mono mb-3">EXPLORE</div>
      <h1 class="text-3xl sm:text-5xl leading-tight tracking-tight font-semibold">主题地图</h1>
      <p class="mt-4 text-base sm:text-lg text-[var(--text-secondary)] leading-relaxed font-light">
        全站 {stats.total} 篇文章按 LLM embedding 投影到 2D 平面，相近 = 主题相关。
        靠近的点常常是同主题不同时期的笔记。
      </p>
      <div class="mt-5 flex flex-wrap gap-4 text-xs">
        <span class="inline-flex items-center gap-1.5">
          <i class="w-2.5 h-2.5 rounded-full" style="background:#1d4ed8"></i>
          <span class="text-[var(--text-secondary)]">AI <span class="font-mono text-[var(--text-tertiary)]">{stats.ai}</span></span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <i class="w-2.5 h-2.5 rounded-full" style="background:#991b1b"></i>
          <span class="text-[var(--text-secondary)]">投资 <span class="font-mono text-[var(--text-tertiary)]">{stats.invest}</span></span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <i class="w-2.5 h-2.5 rounded-full" style="background:#166534"></i>
          <span class="text-[var(--text-secondary)]">徒步 <span class="font-mono text-[var(--text-tertiary)]">{stats.hike}</span></span>
        </span>
      </div>
    </header>

    {points.length === 0 ? (
      <p class="text-[var(--text-tertiary)]">embeddings.json 还没数据。等 daily-digest workflow 跑完后回来。</p>
    ) : (
      <div class="relative w-full bg-[var(--bg-soft)] rounded-2xl border border-[var(--border)] overflow-hidden">
        <svg viewBox={`0 0 ${VBW} ${VBH}`} class="w-full h-auto block" preserveAspectRatio="xMidYMid meet">
          {points.map((p) => {
            const m = metaMap.get(p.key);
            if (!m) return null;
            const { cx, cy } = toSvg(p.x, p.y);
            const color = colorMap[m.collection] ?? "#71717a";
            const r = m.isDigest ? 0.7 : 1.1;
            const opacity = m.isDigest ? 0.55 : 1;
            return (
              <a href={`/${m.collection}/${m.key}`} class="explore-point">
                <circle cx={cx} cy={cy} r={r} fill={color} opacity={opacity}
                        class="transition-all hover:r-2 hover:opacity-100" />
                <title>{m.title} · {m.date.toISOString().slice(0, 10)}</title>
              </a>
            );
          })}
        </svg>
      </div>
    )}

    <section class="mt-8 text-sm text-[var(--text-secondary)] leading-relaxed">
      <p>
        <strong>实现</strong>：每篇文章 (title + description + body 前 800 字) 走豆包 embedding 拿 2048 维向量，
        然后用 PCA (主成分分析) 把所有向量投影到能最大化方差的 2D 平面。距离近的两个点 = 内容语义相似度高。
      </p>
      <p class="mt-3">
        <strong>读法</strong>：
        点击任意点跳到对应文章。空心 / 半透明的小点是 digest（自动日报），实心大点是原创。
        如果某区域聚成一团，那是同主题被反复写到。
      </p>
    </section>

  </article>
</BaseLayout>

<style>
  .explore-point { cursor: pointer; }
  .explore-point circle:hover { r: 2.2; opacity: 1; }
</style>
