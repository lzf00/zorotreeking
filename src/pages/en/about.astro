---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations } from "@/i18n/ui";
const t = useTranslations("en");
---
<BaseLayout title={t("nav.about")}>
  <article class="max-w-prose mx-auto px-5 pt-16 pb-16">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight mb-6">About</h1>
    <div class="prose prose-neutral dark:prose-invert max-w-none">
      <p>Welcome to <strong>ZoroTreeking</strong>. A personal site where I keep notes and records across four interests:</p>
      <ul>
        <li><strong>AI Learning</strong> — paper notes, tool experiments, technical thoughts</li>
        <li><strong>Investment</strong> — account reviews and monthly records (personal learning log, not investment advice)</li>
        <li><strong>Photography</strong> — albums organized by theme, location and year</li>
        <li><strong>Hiking</strong> — route tracks, elevation profiles, trip logs</li>
      </ul>
      <p>All content is personal, original or curated. Feel free to leave a comment.</p>
      <hr />
      <p class="text-sm text-[var(--text-secondary)]">Open-sourced on <a href="https://github.com/lzf00/zorotreeking">GitHub</a>, built with Astro 4, deployed automatically. This is a non-commercial personal site — no commerce, transactions or user-generated content.</p>
    </div>
  </article>
</BaseLayout>
