---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";

export async function getStaticPaths() {
  const all = await getCollection("invest", (p) => p.data.lang === "en" && !p.data.draft);
  return all.map((entry) => ({ params: { slug: entry.data.translationKey }, props: { entry } }));
}

interface Props { entry: CollectionEntry<"invest"> }
const { entry } = Astro.props;
const { Content } = await entry.render();
const lang = "en" as const;
const t = useTranslations(lang);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-prose mx-auto px-5 pt-12 pb-16">
    <header class="mb-6">
      <a href={pathWithLang("/invest", lang)} class="text-sm text-section-invest hover:underline">← {t("section.invest.title")}</a>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight leading-tight">{entry.data.title}</h1>
      <div class="mt-3 flex items-center gap-3 text-xs text-[var(--text-tertiary)]">
        <time>{entry.data.date.toISOString().slice(0, 10)}</time>
        {entry.data.tags.map((tag) => <span class="px-1.5 py-0.5 rounded bg-[var(--bg-soft)]">#{tag}</span>)}
      </div>
    </header>
    <div class="prose prose-neutral dark:prose-invert max-w-none prose-headings:tracking-tight prose-a:text-section-invest">
      <Content />
    </div>
  </article>
</BaseLayout>
