---
/**
 * /en/invest/stock/[code] — Single stock deep dive panel (English UI)
 * Mirrors /invest/stock/[code] — shares src/data/wind-stock-details.json.
 */
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";

type Consensus = { target_price?: number; buy_count?: number; overweight_count?: number; total_ratings?: number; coverage?: number; error?: string };
type Item = { title: string; date: string; snippet: string; error?: string };
type ShortTrend = { date: string; amount_yi: number; ratio_market?: number | null };
type CapitalFlow = {
  market: "A" | "HK";
  main_buy_yi?: number; main_sell_yi?: number;
  short_amount_today_yi?: number; short_ratio_market_today?: number;
  short_trend_5d?: ShortTrend[];
  error?: string;
};
type Connect = { holding_pct?: number; error?: string };
type Stock = {
  market: "A" | "HK";
  code: string; name: string;
  price: number; yesterday_close: number; open: number; high: number; low: number;
  amount_yi: number; change_pct: number; amplitude: number;
  turnover?: number;
  chg_5d: number; chg_20d: number; chg_ytd: number;
  pe_ttm?: number; pb?: number; dividend_yield?: number;
  high_52w?: number; low_52w?: number;
  main_net_today_yi?: number; main_net_5d_yi?: number; main_net_5d_pct?: number;
  main_net_10d_yi?: number; main_net_20d_yi?: number;
  currency?: string;
  emoji: string;
  details?: { consensus?: Consensus; capital_flow?: CapitalFlow; connect?: Connect; announcements?: Item[]; news?: Item[] };
  error?: string;
};
type Snapshot = { asOf: string; date: string; stocks: Record<string, Stock> };

const snapshotPath = path.resolve("./src/data/wind-stock-details.json");
let snap: Snapshot | null = null;
try { snap = JSON.parse(fs.readFileSync(snapshotPath, "utf-8")); } catch { snap = null; }

export async function getStaticPaths() {
  const p = path.resolve("./src/data/wind-stock-details.json");
  try {
    const data: Snapshot = JSON.parse(fs.readFileSync(p, "utf-8"));
    return Object.keys(data.stocks || {}).map((code) => ({ params: { code }, props: { code } }));
  } catch { return []; }
}

const { code } = Astro.props as { code: string };
const stock = snap?.stocks?.[code] || null;
const lang = "en" as const;
const t = useTranslations(lang);

function fmt(v: number | null | undefined, digits = 2, unit = ""): string {
  if (v == null || !Number.isFinite(Number(v))) return "—";
  return `${Number(v).toFixed(digits)}${unit}`;
}
function fmtPrice(v: number | null | undefined): string {
  if (v == null || !Number.isFinite(Number(v)) || Number(v) === 0) return "—";
  return Number(v).toFixed(2);
}
function fmtPct(v: number | null | undefined): string {
  if (v == null) return "—";
  const n = Number(v);
  if (!Number.isFinite(n)) return "—";
  return `${n >= 0 ? "+" : ""}${n.toFixed(2)}%`;
}
function colorClass(v: number | null | undefined): string {
  if (v == null || !Number.isFinite(Number(v))) return "text-[var(--text-tertiary)]";
  const n = Number(v);
  if (n > 0) return "text-red-600 dark:text-red-400";
  if (n < 0) return "text-emerald-600 dark:text-emerald-400";
  return "text-[var(--text-tertiary)]";
}
function fmtYi(v: number | null | undefined): string {
  if (v == null || !Number.isFinite(Number(v))) return "—";
  const n = Number(v);
  return `${n >= 0 ? "+" : ""}${n.toFixed(2)} ¥100M`;
}
function baiduSearch(q: string): string {
  return `https://www.baidu.com/s?wd=${encodeURIComponent(q)}`;
}

const within52w = (price?: number, lo?: number, hi?: number) => {
  if (!price || !lo || !hi || hi <= lo) return null;
  return ((price - lo) / (hi - lo)) * 100;
};
const pct52w = stock ? within52w(stock.price, stock.low_52w, stock.high_52w) : null;
const upside = (() => {
  if (!stock?.details?.consensus?.target_price || !stock.price) return null;
  return ((stock.details.consensus.target_price - stock.price) / stock.price) * 100;
})();

const currency = stock?.currency || "CNY";
const ccySym = currency === "HKD" ? "HK$" : "¥";
const backHref = stock?.market === "HK" ? pathWithLang("/invest/hk-market", lang) : pathWithLang("/invest/market", lang);
const backText = stock?.market === "HK" ? "HK market dashboard" : "Market dashboard";
---

<BaseLayout
  title={stock ? `${stock.name} (${stock.code}) · Stock deep dive` : "Stock deep dive"}
  description={stock ? `${stock.name} — quote, multi-period, valuation, fund flow, consensus, filings, news (Wind data)` : ""}
>
  <section class="max-w-5xl mx-auto px-5 pt-12 pb-4">
    <a href={backHref} class="text-sm text-section-invest hover:underline">← {backText}</a>

    {!stock && (
      <div class="mt-8 text-center py-12">
        <p class="text-[var(--text-secondary)]">No data for <code class="text-xs font-mono">{code}</code>.</p>
        <p class="mt-2 text-xs text-[var(--text-tertiary)]">
          Stock details are generated by stock_pusher after 15:30 China time on trading days.
        </p>
      </div>
    )}

    {stock && (
      <>
        <div class="mt-3 flex flex-wrap items-baseline gap-x-4 gap-y-2">
          <h1 class="font-serif text-3xl sm:text-4xl leading-[1] tracking-tight">{stock.name}</h1>
          <span class="text-sm font-mono text-[var(--text-tertiary)]">{stock.code}</span>
          <span class="text-xs px-2 py-0.5 rounded bg-[var(--surface-2)] text-[var(--text-secondary)]">{stock.market === "HK" ? "HK" : "A-share"}</span>
        </div>
        <div class="mt-3 flex items-baseline gap-3">
          <span class="text-3xl font-mono font-semibold">{ccySym} {fmtPrice(stock.price)}</span>
          <span class={`text-base font-mono font-semibold ${colorClass(stock.change_pct)}`}>{fmtPct(stock.change_pct)}</span>
          <span class="text-xs text-[var(--text-tertiary)]">
            {currency} · {snap?.asOf ? new Date(snap.asOf).toLocaleString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" }) : ""}
          </span>
        </div>
      </>
    )}
  </section>

  {stock && (
    <>
      <section class="max-w-5xl mx-auto px-5 pb-8">
        <h2 class="text-base font-semibold tracking-tight mb-3">📈 Quote snapshot</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">Open</div><div class="mt-0.5 font-mono">{fmtPrice(stock.open)}</div></div>
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">Prev close</div><div class="mt-0.5 font-mono">{fmtPrice(stock.yesterday_close)}</div></div>
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">High</div><div class="mt-0.5 font-mono">{fmtPrice(stock.high)}</div></div>
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">Low</div><div class="mt-0.5 font-mono">{fmtPrice(stock.low)}</div></div>
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">Amplitude</div><div class="mt-0.5 font-mono">{fmt(stock.amplitude, 2, "%")}</div></div>
          {stock.turnover != null && stock.turnover > 0 && (
            <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">Turnover</div><div class="mt-0.5 font-mono">{fmt(stock.turnover, 2, "%")}</div></div>
          )}
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">Volume value</div><div class="mt-0.5 font-mono">{fmt(stock.amount_yi, 2, " ¥100M")}</div></div>
          <div class="border border-[var(--border)] rounded-lg p-3">
            <div class="text-[10px] text-[var(--text-tertiary)]">52-week range</div>
            <div class="mt-0.5 font-mono text-xs">{fmtPrice(stock.low_52w)} - {fmtPrice(stock.high_52w)}</div>
            {pct52w != null && (
              <div class="mt-1">
                <div class="h-1.5 bg-[var(--surface-2)] rounded-full overflow-hidden">
                  <div class="h-full bg-section-invest" style={`width: ${Math.max(0, Math.min(100, pct52w)).toFixed(1)}%`}></div>
                </div>
                <div class="mt-0.5 text-[10px] text-[var(--text-tertiary)] font-mono">at {pct52w.toFixed(0)}%</div>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-5 pb-8">
        <h2 class="text-base font-semibold tracking-tight mb-3">📊 Multi-period change</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="border border-[var(--border)] rounded-lg p-3 text-center">
            <div class="text-[10px] text-[var(--text-tertiary)]">Today</div>
            <div class={`mt-1 font-mono font-semibold ${colorClass(stock.change_pct)}`}>{fmtPct(stock.change_pct)}</div>
          </div>
          <div class="border border-[var(--border)] rounded-lg p-3 text-center">
            <div class="text-[10px] text-[var(--text-tertiary)]">5D</div>
            <div class={`mt-1 font-mono font-semibold ${colorClass(stock.chg_5d)}`}>{fmtPct(stock.chg_5d)}</div>
          </div>
          <div class="border border-[var(--border)] rounded-lg p-3 text-center">
            <div class="text-[10px] text-[var(--text-tertiary)]">20D</div>
            <div class={`mt-1 font-mono font-semibold ${colorClass(stock.chg_20d)}`}>{fmtPct(stock.chg_20d)}</div>
          </div>
          <div class="border border-[var(--border)] rounded-lg p-3 text-center">
            <div class="text-[10px] text-[var(--text-tertiary)]">YTD</div>
            <div class={`mt-1 font-mono font-semibold ${colorClass(stock.chg_ytd)}`}>{fmtPct(stock.chg_ytd)}</div>
          </div>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-5 pb-8">
        <h2 class="text-base font-semibold tracking-tight mb-3">📐 Valuation</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">P/E (TTM)</div><div class="mt-0.5 text-lg font-mono">{stock.pe_ttm && stock.pe_ttm > 0 ? stock.pe_ttm.toFixed(2) : "—"}</div></div>
          <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">P/B</div><div class="mt-0.5 text-lg font-mono">{stock.pb && stock.pb > 0 ? stock.pb.toFixed(2) : "—"}</div></div>
          {stock.dividend_yield != null && stock.dividend_yield > 0 && (
            <div class="border border-[var(--border)] rounded-lg p-3"><div class="text-[10px] text-[var(--text-tertiary)]">Dividend yield</div><div class="mt-0.5 text-lg font-mono text-red-600">{stock.dividend_yield.toFixed(2)}%</div></div>
          )}
        </div>
      </section>

      {stock.market === "A" && (
        <section class="max-w-5xl mx-auto px-5 pb-8">
          <h2 class="text-base font-semibold tracking-tight mb-3">💰 Main capital net flow</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <div class="border border-[var(--border)] rounded-lg p-3 text-center">
              <div class="text-[10px] text-[var(--text-tertiary)]">Today</div>
              <div class={`mt-1 font-mono font-semibold ${colorClass(stock.main_net_today_yi)}`}>{fmtYi(stock.main_net_today_yi)}</div>
            </div>
            <div class="border border-[var(--border)] rounded-lg p-3 text-center">
              <div class="text-[10px] text-[var(--text-tertiary)]">5D</div>
              <div class={`mt-1 font-mono font-semibold ${colorClass(stock.main_net_5d_yi)}`}>{fmtYi(stock.main_net_5d_yi)}</div>
              {stock.main_net_5d_pct != null && (
                <div class={`mt-0.5 text-[10px] font-mono ${colorClass(stock.main_net_5d_pct)}`}>{fmtPct(stock.main_net_5d_pct)} of vol</div>
              )}
            </div>
            <div class="border border-[var(--border)] rounded-lg p-3 text-center">
              <div class="text-[10px] text-[var(--text-tertiary)]">10D</div>
              <div class={`mt-1 font-mono font-semibold ${colorClass(stock.main_net_10d_yi)}`}>{fmtYi(stock.main_net_10d_yi)}</div>
            </div>
            <div class="border border-[var(--border)] rounded-lg p-3 text-center">
              <div class="text-[10px] text-[var(--text-tertiary)]">20D</div>
              <div class={`mt-1 font-mono font-semibold ${colorClass(stock.main_net_20d_yi)}`}>{fmtYi(stock.main_net_20d_yi)}</div>
            </div>
          </div>
        </section>
      )}

      {/* Capital signal: A-share main buy/sell · HK short pressure · Northbound/Southbound */}
      {(stock.details?.capital_flow || stock.details?.connect) && (
        <section class="max-w-5xl mx-auto px-5 pb-8">
          {stock.market === "A" ? (
            <h2 class="text-base font-semibold tracking-tight mb-3">🏢 Capital signal</h2>
          ) : (
            <h2 class="text-base font-semibold tracking-tight mb-3">📉 Short pressure + capital signal</h2>
          )}

          {stock.market === "A" && stock.details?.capital_flow?.main_buy_yi != null && (
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-3">
              <div class="border border-[var(--border)] rounded-lg p-3 text-center">
                <div class="text-[10px] text-[var(--text-tertiary)]">Main buy today</div>
                <div class="mt-1 font-mono font-semibold text-red-600">+{stock.details.capital_flow.main_buy_yi.toFixed(2)} ¥100M</div>
              </div>
              <div class="border border-[var(--border)] rounded-lg p-3 text-center">
                <div class="text-[10px] text-[var(--text-tertiary)]">Main sell today</div>
                <div class="mt-1 font-mono font-semibold text-emerald-600">-{(stock.details.capital_flow.main_sell_yi ?? 0).toFixed(2)} ¥100M</div>
              </div>
              <div class="border border-[var(--border)] rounded-lg p-3 text-center">
                {(() => {
                  const buy = stock.details!.capital_flow!.main_buy_yi!;
                  const sell = stock.details!.capital_flow!.main_sell_yi ?? 0;
                  const net = buy - sell;
                  const isUp = net > 0;
                  return (
                    <>
                      <div class="text-[10px] text-[var(--text-tertiary)]">Main net</div>
                      <div class={`mt-1 font-mono font-semibold ${isUp ? "text-red-600" : net < 0 ? "text-emerald-600" : ""}`}>
                        {isUp ? "+" : ""}{net.toFixed(2)} ¥100M
                      </div>
                    </>
                  );
                })()}
              </div>
            </div>
          )}

          {stock.market === "HK" && stock.details?.capital_flow?.short_amount_today_yi != null && (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
              <div class="border border-[var(--border)] rounded-lg p-3">
                <div class="text-[10px] text-[var(--text-tertiary)]">Short selling today</div>
                <div class="mt-1 text-lg font-mono font-semibold">HK$ {stock.details.capital_flow.short_amount_today_yi.toFixed(2)} ¥100M</div>
              </div>
              {stock.details.capital_flow.short_ratio_market_today != null && (
                <div class="border border-[var(--border)] rounded-lg p-3">
                  <div class="text-[10px] text-[var(--text-tertiary)]">% of total market short</div>
                  <div class="mt-1 text-lg font-mono font-semibold">{stock.details.capital_flow.short_ratio_market_today.toFixed(2)}%</div>
                </div>
              )}
            </div>
          )}

          {stock.market === "HK" && stock.details?.capital_flow?.short_trend_5d && stock.details.capital_flow.short_trend_5d.length > 0 && (
            <div class="border border-[var(--border)] rounded-lg overflow-hidden mb-3">
              <div class="bg-[var(--surface-2)] px-3 py-2 text-xs text-[var(--text-secondary)] font-semibold">5-day short selling trend</div>
              <table class="w-full text-sm">
                <thead class="text-[10px] text-[var(--text-tertiary)]">
                  <tr><th class="text-left px-3 py-1.5">Date</th><th class="text-right px-3">Short amt (¥100M)</th><th class="text-right px-3">% market</th></tr>
                </thead>
                <tbody class="divide-y divide-[var(--border)]">
                  {stock.details.capital_flow.short_trend_5d.map((t) => (
                    <tr>
                      <td class="px-3 py-1.5 font-mono text-xs">{t.date}</td>
                      <td class="text-right px-3 font-mono">{t.amount_yi?.toFixed(2)}</td>
                      <td class="text-right px-3 font-mono text-[var(--text-secondary)]">{t.ratio_market != null ? `${t.ratio_market.toFixed(2)}%` : "—"}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {stock.details?.connect?.holding_pct != null && (
            <div class="border border-[var(--border)] rounded-lg p-3">
              <div class="flex items-baseline justify-between">
                <div>
                  <div class="text-[10px] text-[var(--text-tertiary)]">{stock.market === "HK" ? "Southbound (HK Connect) holding %" : "Northbound (Stock Connect) holding %"}</div>
                  <div class="mt-1 text-lg font-mono font-semibold">{stock.details.connect.holding_pct.toFixed(2)}%</div>
                </div>
                <span class="text-[10px] text-[var(--text-tertiary)] font-mono">Wind</span>
              </div>
            </div>
          )}

          {stock.market === "A" && (!stock.details?.capital_flow?.main_buy_yi && !stock.details?.connect?.holding_pct) && (
            <p class="text-xs text-[var(--text-tertiary)]">⏳ Capital signal data not returned by Wind today</p>
          )}
          {stock.market === "HK" && (!stock.details?.capital_flow?.short_amount_today_yi && !stock.details?.connect?.holding_pct) && (
            <p class="text-xs text-[var(--text-tertiary)]">⏳ Short/Southbound data not returned by Wind today</p>
          )}
        </section>
      )}

      {stock.details?.consensus && !stock.details.consensus.error && (
        <section class="max-w-5xl mx-auto px-5 pb-8">
          <h2 class="text-base font-semibold tracking-tight mb-3">🎯 Analyst consensus</h2>
          <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
            {stock.details.consensus.target_price != null && (
              <div class="border border-[var(--border)] rounded-lg p-3 sm:col-span-2">
                <div class="text-[10px] text-[var(--text-tertiary)]">Consensus target price</div>
                <div class="mt-0.5 flex items-baseline gap-2">
                  <span class="text-xl font-mono font-semibold">{ccySym} {stock.details.consensus.target_price.toFixed(2)}</span>
                  {upside != null && (
                    <span class={`text-sm font-mono ${colorClass(upside)}`}>{upside >= 0 ? "↑" : "↓"} {Math.abs(upside).toFixed(1)}%</span>
                  )}
                </div>
                {upside != null && (
                  <div class="mt-1 text-[10px] text-[var(--text-tertiary)]">
                    upside vs current {ccySym} {stock.price?.toFixed(2)}
                  </div>
                )}
              </div>
            )}
            {stock.details.consensus.buy_count != null && (
              <div class="border border-[var(--border)] rounded-lg p-3 text-center">
                <div class="text-[10px] text-[var(--text-tertiary)]">Buy ratings</div>
                <div class="mt-1 text-xl font-mono font-semibold text-red-600">{stock.details.consensus.buy_count}</div>
              </div>
            )}
            {stock.details.consensus.overweight_count != null && (
              <div class="border border-[var(--border)] rounded-lg p-3 text-center">
                <div class="text-[10px] text-[var(--text-tertiary)]">Overweight ratings</div>
                <div class="mt-1 text-xl font-mono font-semibold text-red-500">{stock.details.consensus.overweight_count}</div>
              </div>
            )}
          </div>
          {stock.details.consensus.total_ratings != null && (
            <p class="mt-2 text-[11px] text-[var(--text-tertiary)]">
              Total broker ratings: {stock.details.consensus.total_ratings}
              {stock.details.consensus.buy_count != null && stock.details.consensus.overweight_count != null && (
                <>
                  · Buy + overweight: {(((stock.details.consensus.buy_count + stock.details.consensus.overweight_count) / stock.details.consensus.total_ratings) * 100).toFixed(1)}%
                </>
              )}
            </p>
          )}
        </section>
      )}

      {stock.details?.announcements && stock.details.announcements.length > 0 && (
        <section class="max-w-5xl mx-auto px-5 pb-8">
          <h2 class="text-base font-semibold tracking-tight mb-3">📋 Recent filings</h2>
          <ol class="space-y-3">
            {stock.details.announcements.map((a) => a.error ? (
              <li class="text-xs text-[var(--text-tertiary)]">⚠️ {a.error}</li>
            ) : (
              <li class="border border-[var(--border)] rounded-lg p-3">
                <a href={baiduSearch(a.title)} target="_blank" rel="noopener noreferrer"
                   class="font-medium text-section-invest hover:underline">{a.title}</a>
                {a.date && <span class="ml-2 text-[10px] font-mono text-[var(--text-tertiary)]">{a.date}</span>}
                {a.snippet && <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed">{a.snippet}…</p>}
              </li>
            ))}
          </ol>
        </section>
      )}

      {stock.details?.news && stock.details.news.length > 0 && (
        <section class="max-w-5xl mx-auto px-5 pb-12">
          <h2 class="text-base font-semibold tracking-tight mb-3">📰 Related news</h2>
          <ol class="space-y-3">
            {stock.details.news.map((n) => n.error ? (
              <li class="text-xs text-[var(--text-tertiary)]">⚠️ {n.error}</li>
            ) : (
              <li class="border border-[var(--border)] rounded-lg p-3">
                <a href={baiduSearch(n.title)} target="_blank" rel="noopener noreferrer"
                   class="font-medium text-section-invest hover:underline">{n.title}</a>
                {n.date && <span class="ml-2 text-[10px] font-mono text-[var(--text-tertiary)]">{n.date}</span>}
                {n.snippet && <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed">{n.snippet}…</p>}
              </li>
            ))}
          </ol>
          <p class="mt-3 text-[11px] text-[var(--text-tertiary)]">
            Titles link to a Baidu search. **For reference only, not investment advice.**
          </p>
        </section>
      )}
    </>
  )}
