---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import NetValueChart from "@/components/NetValueChart";
import HoldingsPie from "@/components/HoldingsPie";
import { useTranslations, pathWithLang } from "@/i18n/ui";

const lang = "en" as const;
const t = useTranslations(lang);

const snapshots = (await getCollection("invest-portfolio")).sort((a, b) => a.data.period.localeCompare(b.data.period));
const baseValue = snapshots[0]?.data.totalValue ?? 1;
const nvSeries = snapshots.map((s) => ({ period: s.data.period, totalValue: s.data.totalValue, netValue: Math.round((s.data.totalValue / baseValue) * 10000) / 10000 }));
const latest = snapshots[snapshots.length - 1]?.data;
const totalReturn = latest ? ((latest.totalValue / baseValue - 1) * 100).toFixed(2) : "0.00";

const allInvest = (await getCollection("invest", (p) => p.data.lang === lang && !p.data.draft)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const isDigest = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");
const isMarketRecap = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("market-recap") || p.data.translationKey.startsWith("market-recap-");
const isReview = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("review") || p.data.translationKey.includes("review");
const posts = allInvest.filter(isReview);
const marketRecaps = allInvest.filter(isMarketRecap).slice(0, 3);
const digests = allInvest.filter(isDigest);
const latestDigest = digests[0];
---

<BaseLayout title={t("section.invest.title")} description={t("section.invest.desc")}>
  <section class="max-w-5xl mx-auto px-5 pt-12 pb-6">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight" style="color:#991b1b">{t("section.invest.title")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{t("section.invest.desc")}</p>
  </section>

  <!-- Wind dashboards (A-share + HK) -->
  <section class="max-w-5xl mx-auto px-5 pb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href={pathWithLang("/invest/market", lang)}
         class="group block border border-[var(--border)] rounded-lg p-4 hover:border-section-invest transition-colors">
        <div class="text-base font-semibold tracking-tight group-hover:text-section-invest">
          📊 A-share Market →
        </div>
        <p class="mt-1 text-sm text-[var(--text-secondary)]">
          Watchlist · 5D / 20D · Main flow · Top gainers · SW sectors · Stock detail
        </p>
        <span class="mt-2 inline-block text-[10px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind · daily 15:30 CST</span>
      </a>
      <a href={pathWithLang("/invest/hk-market", lang)}
         class="group block border border-[var(--border)] rounded-lg p-4 hover:border-section-invest transition-colors">
        <div class="text-base font-semibold tracking-tight group-hover:text-section-invest">
          🇭🇰 HK Market →
        </div>
        <p class="mt-1 text-sm text-[var(--text-secondary)]">
          HK watchlist · Hang Seng indices · Top gainers · Xiaomi / Tencent / Meituan
        </p>
        <span class="mt-2 inline-block text-[10px] text-[var(--text-tertiary)] font-mono uppercase tracking-wide">Wind · daily 15:30 CST</span>
      </a>
    </div>
  </section>
  {latest && (
    <section class="max-w-5xl mx-auto px-5">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
        <div class="rounded-lg border border-[var(--border)] p-3"><div class="text-xs text-[var(--text-tertiary)]">As of</div><div class="text-sm font-semibold">{latest.period}</div></div>
        <div class="rounded-lg border border-[var(--border)] p-3"><div class="text-xs text-[var(--text-tertiary)]">Total value</div><div class="text-base font-semibold">¥{latest.totalValue.toLocaleString()}</div></div>
        <div class="rounded-lg border border-[var(--border)] p-3"><div class="text-xs text-[var(--text-tertiary)]">Total return</div><div class:list={["text-base font-semibold", parseFloat(totalReturn) >= 0 ? "text-section-invest" : "text-green-600"]}>{parseFloat(totalReturn) >= 0 ? "+" : ""}{totalReturn}%</div></div>
        <div class="rounded-lg border border-[var(--border)] p-3"><div class="text-xs text-[var(--text-tertiary)]">Positions</div><div class="text-base font-semibold">{latest.holdings.length}</div></div>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="rounded-xl border border-[var(--border)] p-4"><h3 class="text-sm font-semibold mb-2">Net value (base = {snapshots[0].data.period})</h3><NetValueChart data={nvSeries} client:visible /></div>
        <div class="rounded-xl border border-[var(--border)] p-4"><h3 class="text-sm font-semibold mb-2">Holdings</h3><HoldingsPie holdings={latest.holdings} client:visible /></div>
      </div>
    </section>
  )}
  {/* ── Zone 1: Monthly review (hand-written, slow) ── */}
  <section class="max-w-5xl mx-auto px-5 mt-12">
    <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-[var(--border)]">
      <h2 class="text-lg font-semibold tracking-tight">🧠 Monthly review</h2>
      <span class="text-xs text-[var(--text-tertiary)] font-mono">
        {posts.length} · monthly
      </span>
    </div>
    {posts.length === 0 ? (
      <div class="py-8 text-center text-sm text-[var(--text-tertiary)]">
        <p>Reviews are on the way.</p>
        <p class="mt-1 text-xs">Goal: one systematic monthly summary — position moves / judgment audit / next-month plan.</p>
      </div>
    ) : (
      <>
        <ul class="divide-y divide-[var(--border)]">
          {posts.map((p) => (
            <li class="py-4">
              <div class="text-xs text-[var(--text-tertiary)] mb-1"><time>{p.data.date.toISOString().slice(0, 10)}</time></div>
              <h3 class="text-base font-semibold">
                <a href={pathWithLang(`/invest/${p.data.translationKey}`, lang)}
                   class="hover:text-section-invest transition-colors">
                  {p.data.title}
                </a>
              </h3>
              {p.data.description && <p class="mt-1 text-sm text-[var(--text-secondary)]">{p.data.description}</p>}
            </li>
          ))}
        </ul>
        {posts.length < 4 && (
          <p class="mt-4 text-xs text-[var(--text-tertiary)] italic">
            Monthly reviews are the slow forcing function for reflection. Below: <a href={pathWithLang("/invest/digest", lang)} class="underline hover:text-section-invest">market news digest</a> and <a href="#market-recap" class="underline hover:text-section-invest">daily market recap</a> — the high-signal auto data streams.
          </p>
        )}
      </>
    )}
  </section>

  {/* ── Zone 2: Daily market recap (cron auto) ── */}
  {marketRecaps.length > 0 && (
    <section id="market-recap" class="max-w-5xl mx-auto px-5 mt-12">
      <div class="flex items-baseline justify-between mb-4 pb-2 border-b border-[var(--border)]">
        <h2 class="text-lg font-semibold tracking-tight">📈 Daily market recap</h2>
        <span class="text-xs text-[var(--text-tertiary)] font-mono">
          cron 15:30 daily · Wind data
        </span>
      </div>
      <ul class="divide-y divide-[var(--border)]">
        {marketRecaps.map(r => (
          <li class="py-3">
            <a href={pathWithLang(`/invest/${r.data.translationKey}`, lang)}
               class="group flex items-baseline justify-between gap-3 hover:text-section-invest">
              <div class="min-w-0 flex-1">
                <span class="text-sm font-medium">{r.data.title}</span>
                {r.data.description && (
                  <p class="mt-0.5 text-xs text-[var(--text-tertiary)] line-clamp-1">{r.data.description}</p>
                )}
              </div>
              <time class="text-xs text-[var(--text-tertiary)] font-mono shrink-0">{r.data.date.toISOString().slice(0, 10)}</time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {digests.length > 0 && (
    <section class="max-w-5xl mx-auto px-5 mt-12 pb-12">
      <a href={pathWithLang("/invest/digest", lang)}
         class="group block border border-[var(--border)] rounded-xl p-5 hover:border-section-invest transition-colors">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.15em] text-[var(--text-tertiary)] font-mono mb-1">Auto Digest</div>
            <h3 class="text-base font-semibold group-hover:text-section-invest transition-colors">Market news digest · archive →</h3>
            <p class="mt-1 text-sm text-[var(--text-secondary)] line-clamp-1">cron at 08:00 Beijing daily: 10jqka / Eastmoney / Yahoo Finance, AI rewrite</p>
          </div>
          <div class="text-right shrink-0">
            <div class="text-2xl font-semibold tabular-nums">{digests.length}</div>
            <div class="text-[11px] uppercase tracking-wider text-[var(--text-tertiary)]">issues</div>
          </div>
        </div>
        {latestDigest && (
          <div class="mt-3 pt-3 border-t border-[var(--border)] text-xs text-[var(--text-tertiary)]">
            Latest: {latestDigest.data.date.toISOString().slice(0, 10)} · {latestDigest.data.description}
          </div>
        )}
      </a>
    </section>
  )}
</BaseLayout>
