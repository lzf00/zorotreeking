---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionCard from "@/components/SectionCard.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";

const lang = "en" as const;
const t = useTranslations(lang);

const [aiPosts, investPosts, photoAlbums, hikes] = await Promise.all([
  getCollection("ai", (p) => p.data.lang === lang && !p.data.draft),
  getCollection("invest", (p) => p.data.lang === lang && !p.data.draft),
  getCollection("photo", (p) => p.data.lang === lang && !p.data.draft),
  getCollection("hike", (p) => p.data.lang === lang && !p.data.draft),
]);

const latest = [
  ...aiPosts.map(p => ({ ...p, section: "ai" as const })),
  ...investPosts.map(p => ({ ...p, section: "invest" as const })),
  ...photoAlbums.map(p => ({ ...p, section: "photo" as const })),
  ...hikes.map(p => ({ ...p, section: "hike" as const })),
]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);

const sectionLabel = {
  ai: t("nav.ai"), invest: t("nav.invest"), photo: t("nav.photo"), hike: t("nav.hike"),
};
const sectionAccent: Record<string, string> = {
  ai: "#1d4ed8", invest: "#991b1b", photo: "#6b21a8", hike: "#166534",
};
---

<BaseLayout>
  <section class="max-w-5xl mx-auto px-5 pt-20 sm:pt-32 pb-16 sm:pb-24 text-center">
    <h1 class="text-5xl sm:text-7xl font-semibold tracking-tight leading-[1.05] animate-rise">
      Slow notes between<br />
      code and mountains.
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-[var(--text-secondary)] max-w-2xl mx-auto leading-relaxed animate-rise delay-100">
      A personal log on AI, investment, photography and hiking.
    </p>
    <div class="mt-10 flex items-center justify-center gap-4 animate-rise delay-200">
      <a href={pathWithLang("/ai", lang)} class="inline-flex items-center gap-1.5 rounded-full bg-black dark:bg-white text-white dark:text-black px-5 py-2.5 text-sm font-medium hover:opacity-90 transition-opacity">
        Start reading
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
      <a href={pathWithLang("/about", lang)} class="inline-flex items-center text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors">
        About →
      </a>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
    <SectionCard href={pathWithLang("/ai", lang)}     title={t("section.ai.title")}     desc={t("section.ai.desc")}     accent="ai"     count={aiPosts.length}     countLabel="posts"  index={0} />
    <SectionCard href={pathWithLang("/invest", lang)} title={t("section.invest.title")} desc={t("section.invest.desc")} accent="invest" count={investPosts.length} countLabel="posts"  index={1} />
    <SectionCard href={pathWithLang("/photo", lang)}  title={t("section.photo.title")}  desc={t("section.photo.desc")}  accent="photo"  count={photoAlbums.length}  countLabel="albums" index={2} />
    <SectionCard href={pathWithLang("/hike", lang)}   title={t("section.hike.title")}   desc={t("section.hike.desc")}   accent="hike"   count={hikes.length}        countLabel="routes" index={3} />
  </section>

  {latest.length > 0 && (
    <section class="max-w-3xl mx-auto px-5 mt-24 sm:mt-32 pb-24">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">{t("home.latest")}</h2>
        <span class="text-sm text-[var(--text-tertiary)]">{latest.length}</span>
      </div>
      <ul class="divide-y divide-[var(--border)]">
        {latest.map((p, i) => (
          <li class="py-4 animate-rise" style={`animation-delay: ${100 + i * 50}ms`}>
            <a href={pathWithLang(`/${p.section}/${p.data.translationKey}`, lang)} class="flex items-center gap-4 group">
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background:${sectionAccent[p.section]}`}></span>
              <span class="text-xs text-[var(--text-tertiary)] uppercase tracking-wide shrink-0 w-20">{sectionLabel[p.section]}</span>
              <span class="flex-1 truncate text-[15px] group-hover:text-[var(--text)] text-[var(--text-secondary)] transition-colors">{p.data.title}</span>
              <time class="text-xs text-[var(--text-tertiary)] shrink-0 tabular-nums">{p.data.date.toISOString().slice(0, 10)}</time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
