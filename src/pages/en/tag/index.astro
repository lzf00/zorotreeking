---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildTagIndex, tagToSlug } from "@/lib/tags";
import { useTranslations, pathWithLang } from "@/i18n/ui";

const lang = "en" as const;
const t = useTranslations(lang);
const { tags } = await buildTagIndex(lang);

function sizeClass(count: number, max: number) {
  const ratio = count / Math.max(1, max);
  if (ratio > 0.66) return "text-xl font-semibold";
  if (ratio > 0.33) return "text-base font-medium";
  return "text-sm";
}
const max = tags[0]?.count ?? 1;
---

<BaseLayout title={t("tag.allTags")} description={t("tag.allTags")}>
  <section class="max-w-3xl mx-auto px-5 pt-12 pb-6">
    <h1 class="text-3xl font-bold tracking-tight">{t("tag.allTags")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{tags.length} {t("tag.title")}</p>
  </section>
  <section class="max-w-3xl mx-auto px-5 pb-16">
    <div class="flex flex-wrap gap-x-3 gap-y-2 leading-relaxed">
      {tags.map(({ tag, count }) => (
        <a href={pathWithLang(`/tag/${tagToSlug(tag)}`, lang)} class={`${sizeClass(count, max)} text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors`}>
          #{tag}<span class="text-[var(--text-tertiary)] ml-1 text-xs">{count}</span>
        </a>
      ))}
      {tags.length === 0 && <p class="text-[var(--text-tertiary)]">{t("tag.empty")}</p>}
    </div>
  </section>
</BaseLayout>
