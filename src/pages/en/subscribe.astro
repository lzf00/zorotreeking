---
import BaseLayout from "@/layouts/BaseLayout.astro";

const feed = "https://www.zorotreeking.online/rss.xml";
const buttondownUser = import.meta.env.PUBLIC_BUTTONDOWN_USERNAME || "zifei";
const webReaders = [
  { name: "Feedly",         url: `https://feedly.com/i/subscription/feed/${encodeURIComponent(feed)}` },
  { name: "Inoreader",      url: `https://www.inoreader.com/?add_feed=${encodeURIComponent(feed)}` },
  { name: "The Old Reader", url: `https://theoldreader.com/feeds/subscribe?url=${encodeURIComponent(feed)}` },
  { name: "NewsBlur",       url: `https://newsblur.com/?url=${encodeURIComponent(feed)}` },
];
const appReaders = [
  { name: "Reeder",         url: `reeder://subscribe/${encodeURIComponent(feed)}` },
  { name: "NetNewsWire",    url: `feed:${feed}` },
  { name: "Unread",         url: `unread:${feed}` },
];
---

<BaseLayout title="Subscribe" description="Follow ZoroTreeking via RSS">
  <section class="max-w-2xl mx-auto px-5 pt-20 sm:pt-28 pb-24 text-center">
    <h1 class="text-4xl sm:text-6xl font-semibold tracking-tight leading-tight">Subscribe</h1>
    <p class="mt-5 text-lg text-[var(--text-secondary)] leading-relaxed">
      New posts pushed automatically. Quiet. No algorithm.<br class="hidden sm:inline" />
      Email or any RSS reader.
    </p>

    {buttondownUser && (
      <div class="mt-10 mx-auto max-w-md">
        <form
          id="buttondown-form"
          action={`https://buttondown.com/api/emails/embed-subscribe/${buttondownUser}`}
          method="post"
          target="buttondown-sink"
          class="flex items-stretch rounded-xl border border-[var(--border)] overflow-hidden">
          <input id="buttondown-email" type="email" name="email" required placeholder="your@email.com"
            class="flex-1 bg-transparent text-sm px-4 py-3 outline-none placeholder:text-[var(--text-tertiary)]" />
          <input type="hidden" name="embed" value="1" />
          <button type="submit"
            class="px-5 py-3 text-sm font-medium bg-black text-white dark:bg-white dark:text-black hover:opacity-90 transition-opacity whitespace-nowrap">
            Subscribe
          </button>
        </form>
        <iframe name="buttondown-sink" title="buttondown response sink"
                class="hidden" aria-hidden="true" tabindex="-1"></iframe>
        <p id="buttondown-hint" class="mt-2 text-xs text-[var(--text-tertiary)]">≤ 2 emails / week. Unsubscribe anytime. Hosted by Buttondown.</p>
        <div id="buttondown-ok" class="mt-3 text-sm text-green-600 hidden items-start gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <span>Submitted! Check your inbox for the <strong>confirmation link</strong> from Buttondown (might be in spam).</span>
        </div>
      </div>

      <div class="mt-12 flex items-center gap-3 max-w-md mx-auto">
        <div class="flex-1 h-px bg-[var(--border)]"></div>
        <span class="text-[11px] uppercase tracking-[0.2em] text-[var(--text-tertiary)]">or RSS</span>
        <div class="flex-1 h-px bg-[var(--border)]"></div>
      </div>
    )}

    <div class="mt-10 mx-auto max-w-md">
      <div class="flex items-stretch rounded-xl border border-[var(--border)] bg-[var(--bg-soft)] overflow-hidden">
        <code id="feed-url" class="flex-1 truncate text-sm font-mono px-4 py-3 text-left text-[var(--text-secondary)] select-all">{feed}</code>
        <button id="copy-feed" type="button" class="px-4 py-3 text-sm font-medium border-l border-[var(--border)] hover:bg-[var(--bg-soft-2)] transition-colors whitespace-nowrap">
          Copy
        </button>
      </div>
      <p id="copy-hint" class="mt-2 text-xs text-[var(--text-tertiary)] h-4"></p>
    </div>

    <div class="mt-12">
      <p class="text-xs uppercase tracking-[0.16em] text-[var(--text-tertiary)] mb-4">Web readers</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {webReaders.map(r => (
          <a href={r.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] px-4 py-2 text-sm hover:bg-[var(--bg-soft)] transition-colors">
            {r.name}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-8">
      <p class="text-xs uppercase tracking-[0.16em] text-[var(--text-tertiary)] mb-4">Native apps <span class="normal-case tracking-normal text-[var(--text-tertiary)]/80">(requires the app installed)</span></p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {appReaders.map(r => (
          <a href={r.url} class="inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] px-4 py-2 text-sm text-[var(--text-secondary)] hover:bg-[var(--bg-soft)] transition-colors">
            {r.name}
          </a>
        ))}
      </div>
    </div>

    <p class="mt-12 text-sm text-[var(--text-tertiary)]">
      Or view the <a href="/rss.xml" class="underline hover:text-[var(--text)] transition-colors">raw XML</a>.
    </p>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const fm = document.getElementById("buttondown-form");
    const okMsg = document.getElementById("buttondown-ok");
    const hintMsg = document.getElementById("buttondown-hint");
    const emailIn = document.getElementById("buttondown-email");
    if (fm && okMsg) {
      fm.addEventListener("submit", () => {
        setTimeout(() => {
          okMsg.classList.remove("hidden");
          okMsg.classList.add("flex");
          hintMsg && hintMsg.classList.add("hidden");
          if (emailIn) emailIn.value = "";
        }, 150);
      });
    }

    const btn = document.getElementById("copy-feed");
    const url = document.getElementById("feed-url");
    const hint = document.getElementById("copy-hint");
    if (!btn || !url) return;
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(url.textContent || "");
        if (hint) hint.textContent = "Copied to clipboard";
        setTimeout(() => { if (hint) hint.textContent = ""; }, 1800);
      } catch (e) {
        const range = document.createRange();
        range.selectNodeContents(url);
        const sel = window.getSelection();
        sel?.removeAllRanges(); sel?.addRange(range);
        if (hint) hint.textContent = "Selected — press Cmd/Ctrl+C to copy";
        setTimeout(() => { if (hint) hint.textContent = ""; }, 2200);
      }
    });
  });
</script>
