---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagChip from "@/components/TagChip.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";

const lang = "en" as const;
const t = useTranslations(lang);
const all = (await getCollection("ai", p => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const isDigest = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");

const posts = all.filter(p => !isDigest(p));
const digests = all.filter(isDigest);
const latestDigest = digests[0];
---

<BaseLayout title={t("section.ai.title")} description={t("section.ai.desc")}>
  <section class="max-w-3xl mx-auto px-5 pt-12 pb-6">
    <h1 class="font-serif text-5xl sm:text-6xl leading-[0.95] tracking-tight" style="color:#1d4ed8">{t("section.ai.title")}</h1>
    <p class="mt-2 text-[var(--text-secondary)]">{t("section.ai.desc")}</p>
  </section>
  <section class="max-w-3xl mx-auto px-5">
    <ul class="divide-y divide-[var(--border)]">
      {posts.map(p => (
        <li class="py-5">
          <div class="flex items-center gap-2 text-xs text-[var(--text-tertiary)] mb-1">
            <time>{p.data.date.toISOString().slice(0, 10)}</time>
            {p.data.tags.slice(0, 3).map(tag => <TagChip tag={tag} lang={lang} />)}
          </div>
          <h2 class="text-lg font-semibold">
            <a href={pathWithLang(`/ai/${p.data.translationKey}`, lang)}
               class="hover:text-section-ai transition-colors">
              {p.data.title}
            </a>
          </h2>
          {p.data.description && <p class="mt-1 text-sm text-[var(--text-secondary)] line-clamp-2">{p.data.description}</p>}
        </li>
      ))}
      {posts.length === 0 && <li class="py-12 text-center text-[var(--text-tertiary)]">No posts yet</li>}
    </ul>
  </section>

  {digests.length > 0 && (
    <section class="max-w-3xl mx-auto px-5 mt-16">
      <a href={pathWithLang("/ai/digest", lang)}
         class="group block border border-[var(--border)] rounded-xl p-5 hover:border-section-ai transition-colors">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="text-[11px] uppercase tracking-[0.15em] text-[var(--text-tertiary)] font-mono mb-1">Auto Digest</div>
            <h3 class="text-base font-semibold group-hover:text-section-ai transition-colors">Daily AI digests · archive →</h3>
            <p class="mt-1 text-sm text-[var(--text-secondary)] line-clamp-1">cron at 08:00 Beijing daily: HF Daily Papers / arxiv / Anthropic / OpenAI / Google Research</p>
          </div>
          <div class="text-right shrink-0">
            <div class="text-2xl font-semibold tabular-nums">{digests.length}</div>
            <div class="text-[11px] uppercase tracking-wider text-[var(--text-tertiary)]">issues</div>
          </div>
        </div>
        {latestDigest && (
          <div class="mt-3 pt-3 border-t border-[var(--border)] text-xs text-[var(--text-tertiary)]">
            Latest: {latestDigest.data.date.toISOString().slice(0, 10)} · {latestDigest.data.description}
          </div>
        )}
      </a>
    </section>
  )}
</BaseLayout>
