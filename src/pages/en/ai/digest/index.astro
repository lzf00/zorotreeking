---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations, pathWithLang } from "@/i18n/ui";
import { extractDigestHighlights, extractTLDR } from "@/lib/digest-highlights";

const lang = "en" as const;
const t = useTranslations(lang);

const isDigest = (p: { data: { tags?: string[]; translationKey: string } }) =>
  (p.data.tags ?? []).includes("digest") || p.data.translationKey.startsWith("digest-");

const digests = (await getCollection("ai", (p) => p.data.lang === lang && !p.data.draft))
  .filter(isDigest)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const groups: Record<string, typeof digests> = {};
for (const d of digests) {
  const ym = d.data.date.toISOString().slice(0, 7);
  (groups[ym] ??= []).push(d);
}
const months = Object.keys(groups).sort().reverse();
---

<BaseLayout
  title="Daily AI digest · archive"
  description={`${digests.length} issues auto-generated daily from HF Daily Papers / arxiv / qbitai / Anthropic etc.`}>
  <section class="max-w-3xl mx-auto px-5 pt-12 pb-8">
    <a href={pathWithLang("/ai", lang)}
       class="inline-block text-[11px] uppercase tracking-[0.2em] text-zinc-500 hover:text-section-ai transition-colors mb-6">
      ← {t("section.ai.title")}
    </a>
    <div class="text-[11px] uppercase tracking-[0.2em] text-zinc-500 font-mono mb-3">Auto Digest</div>
    <h1 class="text-3xl sm:text-5xl leading-tight tracking-tight font-semibold text-section-ai">
      Daily AI digest · archive
    </h1>
    <p class="mt-4 text-base sm:text-lg leading-relaxed text-zinc-500 font-light">
      {digests.length} issues auto-generated at 08:00 Beijing daily, pulling from HF Daily Papers / arxiv cs.LG / qbitai / Anthropic / OpenAI / Google Research.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-5 pb-24">
    {months.map(ym => (
      <div class="mt-12">
        <h2 class="text-xs uppercase tracking-[0.2em] text-zinc-400 font-mono mb-5 pb-2 border-b border-[var(--border)]">
          {ym}
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {groups[ym].map(d => {
            const tldr = extractTLDR(d.body);
            const firstLine = tldr?.summary?.[0] ?? null;
            const tags = tldr?.tags?.slice(0, 3) ?? [];
            const fallbackHighlights = !tldr ? extractDigestHighlights(d.body, 2) : [];
            const cover = d.data.cover;
            return (
              <a href={pathWithLang(`/ai/${d.data.translationKey}`, lang)}
                 class="group block rounded-xl overflow-hidden border border-[var(--border)] hover:border-section-ai transition-colors bg-white dark:bg-zinc-900/40">
                {cover && (
                  <div class="aspect-[16/9] overflow-hidden bg-zinc-100 dark:bg-zinc-800">
                    <img src={cover} alt={d.data.title}
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                         loading="lazy" />
                  </div>
                )}
                <div class="p-4">
                  <time class="text-[10px] uppercase tracking-[0.15em] text-zinc-400 font-mono">
                    {d.data.date.toISOString().slice(0, 10)}
                  </time>
                  <h3 class="mt-1 text-base font-semibold leading-snug group-hover:text-section-ai transition-colors line-clamp-2">
                    {d.data.title}
                  </h3>
                  {firstLine && (
                    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-2">
                      {firstLine}
                    </p>
                  )}
                  {!firstLine && fallbackHighlights.length > 0 && (
                    <ul class="mt-2 space-y-0.5">
                      {fallbackHighlights.map(h => (
                        <li class="text-xs text-zinc-500 line-clamp-1">· {h}</li>
                      ))}
                    </ul>
                  )}
                  {tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1.5">
                      {tags.map(tag => (
                        <span class="text-[10.5px] px-1.5 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-500">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    ))}
    {digests.length === 0 && <p class="py-12 text-center text-zinc-500">No digests yet</p>}
  </section>
</BaseLayout>
