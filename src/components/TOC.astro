---
import type { MarkdownHeading } from "astro";
interface Props { headings: MarkdownHeading[]; label?: string }
const { headings, label = "目录" } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{items.length > 0 && (
  <nav class="hidden xl:block fixed top-24 right-8 max-w-[220px] text-sm">
    <div class="text-xs font-semibold text-[var(--text-tertiary)] uppercase tracking-wider mb-2">{label}</div>
    <ul class="space-y-1.5 border-l border-[var(--border)] pl-3">
      {items.map((h) => (
        <li class:list={[h.depth === 3 ? "pl-3" : ""]}>
          <a href={`#${h.slug}`} class="block text-[var(--text-tertiary)] hover:text-[var(--text)] truncate transition-colors">
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
