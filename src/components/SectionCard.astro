---
interface Props {
  href: string;
  title: string;
  desc: string;
  accent: "ai" | "invest" | "photo" | "hike";
  count?: number;
  countLabel?: string;
  countSecondary?: string;  // "+ 53 期日报" 这种副标注
  index?: number;
}
const { href, title, desc, accent, count, countLabel, countSecondary, index = 0 } = Astro.props;

const accentColor: Record<string, string> = {
  ai: "#1d4ed8",
  invest: "#991b1b",
  photo: "#6b21a8",
  hike: "#166534",
};
const c = accentColor[accent];
---

<a
  href={href}
  class="group relative block rounded-2xl bg-[var(--bg-soft)] hover:bg-[var(--bg-soft-2)] p-7 sm:p-8 flex flex-col gap-3 min-h-[200px] transition-colors duration-300 animate-rise"
  style={`animation-delay: ${120 + index * 80}ms`}
>
  <!-- 顶端：色点 + 计数 -->
  <div class="flex items-center justify-between text-[12px] text-[var(--text-tertiary)]">
    <span class="inline-flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full" style={`background:${c}`}></span>
      <span class="uppercase tracking-[0.12em]">{accent}</span>
    </span>
    {count !== undefined && (
      <span class="tabular-nums text-right">
        {count} {countLabel}
        {countSecondary && (
          <span class="ml-1 text-[10px] opacity-70">{countSecondary}</span>
        )}
      </span>
    )}
  </div>

  <!-- 标题 -->
  <h3 class="text-2xl sm:text-[28px] font-semibold tracking-tight leading-tight" style="color:var(--text)">
    {title}
  </h3>

  <!-- 描述 -->
  <p class="text-sm text-[var(--text-secondary)] leading-relaxed max-w-[28ch]">{desc}</p>

  <!-- 底部箭头：苹果风 → -->
  <div class="mt-auto pt-2 inline-flex items-center gap-1 text-sm font-medium" style={`color:${c}`}>
    <span class="group-hover:translate-x-0.5 transition-transform duration-200">了解更多</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-200">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </div>
</a>
